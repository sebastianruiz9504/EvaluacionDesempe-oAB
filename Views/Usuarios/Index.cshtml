@using EvaluacionDesempenoAB.ViewModels
@model IEnumerable<UsuarioPortalEvaluadorViewModel>

@{
    ViewData["Title"] = "Usuarios a mi cargo";
    var cedulaFiltro = ViewData["CedulaFiltro"] as string;
    var hayUsuarios = Model.Any();
}

<h2 class="mt-4">Usuarios a mi cargo</h2>

<div class="row g-3 mt-1 align-items-end">
    <div class="col-12 col-lg-6">
        <form method="get" class="d-flex flex-wrap gap-2 align-items-end">
            <div class="flex-grow-1">
                <label class="form-label mb-1" for="cedulaFiltro">Filtrar por cédula</label>
                <input id="cedulaFiltro" name="cedula" class="form-control" value="@cedulaFiltro" placeholder="Ingresa la cédula" />
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-outline-secondary">Filtrar</button>
                @if (!string.IsNullOrWhiteSpace(cedulaFiltro))
                {
                    <a class="btn btn-outline-danger" asp-action="Index">Limpiar</a>
                }
            </div>
        </form>
    </div>

    <div class="col-12 col-lg-6">
        <form asp-controller="Evaluaciones" asp-action="Nueva" method="get" class="d-flex flex-wrap gap-2 align-items-end justify-content-lg-end">
            <input type="hidden" id="usuarioEvaluacionId" name="usuarioId" />
            <button type="submit" class="btn btn-primary" id="iniciarEvaluacionBtn" @(hayUsuarios ? "" : "disabled")>
                Iniciar evaluación
            </button>
            <button type="button" class="btn btn-outline-primary d-none" id="solicitarActivacionBtn" data-url="@Url.Action("SolicitarActivacion", "Usuarios")">
                Solicitar activación de evaluación
            </button>
        </form>
    </div>
</div>

@if (!hayUsuarios)
{
    <div class="alert alert-info mt-3">
        No se encontraron usuarios asignados a tu correo como evaluador.
        <br />
        Verifica en Dataverse que la columna <code>crfb7_evaluadorid</code> o la columna
        <code>cr3d2_correoevaluadorsst</code> tengan tu correo exactamente como aparece en
        <code>crfb7_correoelectronico</code>.
    </div>
}
else
{
    <div class="table-responsive mt-3" style="max-height: 60vh; overflow-y: auto;">
        <table class="table table-striped table-bordered mb-0">
            <thead class="table-light">
                <tr>
                    <th>Seleccionar</th>
                    <th>Nombre</th>
                    <th>Cédula</th>
                    <th>Cargo</th>
                    <th>Gerencia</th>
                    <th>Correo</th>
                    <th>Resultado final</th>
                    <th>Inicio de contrato</th>
                    <th>Finalización contrato</th>
                    <th>Finalización período de prueba</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var u in Model)
            {
                <tr>
                    <td class="text-center">
                        <input type="checkbox"
                               class="form-check-input usuario-select"
                               aria-label="Seleccionar usuario"
                               data-id="@u.Id"
                               data-fecha-finalizacion-contrato="@(u.FechaFinalizacionContrato?.ToString("yyyy-MM-dd") ?? "")"
                               data-fecha-finalizacion-prueba="@(u.FechaFinalizacionPeriodoPrueba?.ToString("yyyy-MM-dd") ?? "")"
                               data-fecha-activacion-evaluacion="@(u.FechaActivacionEvaluacion?.ToString("yyyy-MM-dd") ?? "")"
                               data-puede-iniciar="@u.PuedeIniciarEvaluacion.ToString().ToLower()"
                               data-puede-solicitar="@u.PuedeSolicitarActivacion.ToString().ToLower()"
                               data-tiene-evaluacion-activa="@u.TieneEvaluacionActiva.ToString().ToLower()"
                               data-evaluacion-actual-id="@(u.EvaluacionActualId?.ToString() ?? string.Empty)" />
                    </td>
                    <td>
                        <a asp-controller="Usuarios" asp-action="Detalle" asp-route-id="@u.Id" class="link-primary text-decoration-none">
                            @u.NombreCompleto
                        </a>
                    </td>
                    <td>@u.Cedula</td>
                    <td>@u.Cargo</td>
                    <td>@u.Gerencia</td>
                    <td>@u.CorreoElectronico</td>
                    <td>
                        @if (u.ResultadoFinal.HasValue)
                        {
                            @u.ResultadoFinal.Value.ToString("0.##")<span>%</span>
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </td>
                    <td>@(u.FechaInicioContrato?.ToShortDateString() ?? "-")</td>
                    <td>@(u.FechaFinalizacionContrato?.ToShortDateString() ?? "-")</td>
                    <td>@(u.FechaFinalizacionPeriodoPrueba?.ToShortDateString() ?? "-")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

<form id="solicitudActivacionToken" method="post" class="d-none">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    <script>
        (() => {
            const checkboxes = document.querySelectorAll('.usuario-select');
            const iniciarBtn = document.getElementById('iniciarEvaluacionBtn');
            const solicitarBtn = document.getElementById('solicitarActivacionBtn');
            const evalInputId = document.getElementById('usuarioEvaluacionId');
            const estadoActivacionUrlBase = '@Url.Action("EstadoActivacion", "Usuarios")';
            const iniciarBtnDefaultText = iniciarBtn?.textContent?.trim() || 'Iniciar evaluación';
            const activationPollingIntervalMs = 5000;
            const maxActivationPollingAttempts = 120;
            let activationPollingTimer = null;
            let activationPollingUserId = null;
            let activationPollingAttempts = 0;
            let pendingActivationUserId = null;

            const setButtonsState = (canStart, canRequest, hasActiveEvaluation) => {
                if (iniciarBtn) {
                    iniciarBtn.disabled = !canStart;
                    iniciarBtn.textContent = hasActiveEvaluation ? 'Continuar evaluación' : iniciarBtnDefaultText;
                }

                if (solicitarBtn) {
                    if (canRequest) {
                        solicitarBtn.classList.remove('d-none');
                        solicitarBtn.disabled = pendingActivationUserId === solicitarBtn.dataset.userId;
                        solicitarBtn.textContent = pendingActivationUserId === solicitarBtn.dataset.userId
                            ? 'Esperando aprobación...'
                            : 'Solicitar activación de evaluación';
                    } else {
                        solicitarBtn.classList.add('d-none');
                        solicitarBtn.disabled = true;
                        solicitarBtn.textContent = 'Solicitar activación de evaluación';
                    }
                }
            };

            const getSelectedCheckbox = () => document.querySelector('.usuario-select:checked');

            const stopActivationPolling = (clearPending = false) => {
                if (activationPollingTimer) {
                    window.clearTimeout(activationPollingTimer);
                }

                activationPollingTimer = null;
                activationPollingUserId = null;
                activationPollingAttempts = 0;

                if (clearPending) {
                    pendingActivationUserId = null;
                }
            };

            const updateSelection = (refreshRemoteState = true) => {
                const selected = document.querySelector('.usuario-select:checked');
                if (!evalInputId) return;

                if (!selected) {
                    evalInputId.value = '';
                    stopActivationPolling();
                    setButtonsState(false, false, false);
                    return;
                }

                evalInputId.value = selected.dataset.id || '';
                if (solicitarBtn) solicitarBtn.dataset.userId = selected.dataset.id || '';
                const puedeIniciar = selected.dataset.puedeIniciar === 'true';
                const puedeSolicitar = selected.dataset.puedeSolicitar === 'true';
                const tieneEvaluacionActiva = selected.dataset.tieneEvaluacionActiva === 'true' ||
                    !!selected.dataset.evaluacionActualId;
                setButtonsState(puedeIniciar, puedeSolicitar, tieneEvaluacionActiva);

                if (refreshRemoteState && !puedeIniciar && puedeSolicitar) {
                    startActivationPolling(selected.dataset.id || '', selected, true);
                } else if (puedeIniciar || activationPollingUserId !== selected.dataset.id) {
                    stopActivationPolling(puedeIniciar);
                }
            };

            const sleep = (ms) => new Promise((resolve) => window.setTimeout(resolve, ms));

            const refreshActivationState = async (userId, selectedCheckbox) => {
                if (!userId || !estadoActivacionUrlBase) return false;

                const url = `${estadoActivacionUrlBase}?usuarioId=${encodeURIComponent(userId)}&_=${Date.now()}`;
                const response = await fetch(url, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    cache: 'no-store'
                });

                if (!response.ok) throw new Error('No fue posible consultar el estado de activación.');

                const data = await response.json();
                if (selectedCheckbox) {
                    selectedCheckbox.dataset.fechaActivacionEvaluacion = data.fechaActivacionEvaluacion || '';
                    selectedCheckbox.dataset.puedeIniciar = data.puedeIniciar === true ? 'true' : 'false';
                    selectedCheckbox.dataset.puedeSolicitar = data.puedeSolicitar === true ? 'true' : 'false';
                    selectedCheckbox.dataset.tieneEvaluacionActiva = data.tieneEvaluacionActiva === true ? 'true' : 'false';
                    selectedCheckbox.dataset.evaluacionActualId = data.evaluacionActualId || '';
                }
                updateSelection(false);
                return data.puedeIniciar === true;
            };

            function startActivationPolling(userId, selectedCheckbox, immediate = false) {
                if (!userId || !selectedCheckbox) return;

                if (activationPollingUserId && activationPollingUserId !== userId) {
                    stopActivationPolling();
                }

                if (activationPollingTimer) {
                    return;
                }

                activationPollingUserId = userId;

                const poll = async () => {
                    activationPollingTimer = null;

                    const selected = getSelectedCheckbox();
                    if (!selected || selected.dataset.id !== userId) {
                        stopActivationPolling();
                        return;
                    }

                    try {
                        const activado = await refreshActivationState(userId, selected);
                        if (activado) {
                            stopActivationPolling(true);
                            updateSelection(false);
                            return;
                        }
                    } catch (error) {
                        // La pantalla seguirá intentando mientras el usuario permanezca seleccionado.
                    }

                    activationPollingAttempts++;
                    if (activationPollingAttempts >= maxActivationPollingAttempts) {
                        stopActivationPolling(true);
                        updateSelection(false);
                        return;
                    }

                    activationPollingTimer = window.setTimeout(poll, activationPollingIntervalMs);
                };

                activationPollingTimer = window.setTimeout(poll, immediate ? 0 : activationPollingIntervalMs);
            }

            checkboxes.forEach((checkbox) => {
                checkbox.addEventListener('change', (event) => {
                    if (event.target.checked) {
                        checkboxes.forEach((other) => {
                            if (other !== event.target) other.checked = false;
                        });
                    }
                    updateSelection();
                });
            });

            if (solicitarBtn) {
                solicitarBtn.addEventListener('click', async () => {
                    const userId = solicitarBtn.dataset.userId;
                    const url = solicitarBtn.dataset.url;
                    const tokenInput = document.querySelector('#solicitudActivacionToken input[name="__RequestVerificationToken"]');

                    if (!userId || !url || !tokenInput) return;

                    solicitarBtn.disabled = true;
                    solicitarBtn.textContent = 'Enviando solicitud...';

                    try {
                        const response = await fetch(url, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': tokenInput.value
                            },
                            body: JSON.stringify({ usuarioId: userId })
                        });

                        if (!response.ok) throw new Error('Solicitud fallida');

                        pendingActivationUserId = userId;
                        solicitarBtn.textContent = 'Solicitud enviada';

                        const selectedCheckbox = document.querySelector(`.usuario-select[data-id="${userId}"]`);
                        let activado = false;
                        for (let intento = 0; intento < 6; intento++) {
                            if (intento > 0) await sleep(2000);
                            activado = await refreshActivationState(userId, selectedCheckbox);
                            if (activado) break;
                        }

                        if (activado) {
                            stopActivationPolling(true);
                            updateSelection(false);
                        } else {
                            solicitarBtn.textContent = 'Esperando aprobación...';
                            startActivationPolling(userId, selectedCheckbox, false);
                        }
                    } catch (error) {
                        if (pendingActivationUserId === userId) {
                            pendingActivationUserId = null;
                        }

                        stopActivationPolling();
                        solicitarBtn.disabled = false;
                        solicitarBtn.textContent = 'Reintentar solicitud';
                    }
                });
            }

            updateSelection();
        })();
    </script>
}
