@using EvaluacionDesempenoAB.Models
@model IEnumerable<UsuarioEvaluado>

@{
    ViewData["Title"] = "Módulo admin";
    var cedulaFiltro = ViewData["CedulaFiltro"] as string;
    var hayUsuarios = Model.Any();
}

<h2 class="mt-4">Módulo admin</h2>

@if (TempData["AdminFotoSuccess"] is string fotoSuccess)
{
    <div class="alert alert-success mt-3">
        @fotoSuccess
    </div>
}

@if (TempData["AdminFotoError"] is string fotoError)
{
    <div class="alert alert-danger mt-3">
        @fotoError
    </div>
}

<div class="row g-3 mt-1 align-items-end">
    <div class="col-12 col-lg-5">
        <form method="get" class="d-flex flex-wrap gap-2 align-items-end">
            <div class="flex-grow-1">
                <label class="form-label mb-1" for="cedulaFiltro">Filtrar por cédula</label>
                <input id="cedulaFiltro"
                       name="cedula"
                       class="form-control"
                       value="@cedulaFiltro"
                       placeholder="Ingresa la cédula" />
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-outline-secondary">Filtrar</button>
                @if (!string.IsNullOrWhiteSpace(cedulaFiltro))
                {
                    <a class="btn btn-outline-danger" asp-action="Index">Limpiar</a>
                }
            </div>
        </form>
    </div>

    <div class="col-12 col-lg-4">
        <form asp-controller="Evaluaciones" asp-action="Nueva" method="get" class="d-flex flex-wrap gap-2 align-items-end">
            <input type="hidden" id="usuarioEvaluacionId" name="usuarioId" />
            <button type="submit" class="btn btn-primary" id="iniciarEvaluacionBtn" @(hayUsuarios ? "" : "disabled")>
                Iniciar evaluación
            </button>
            <button type="button"
                    class="btn btn-outline-primary"
                    data-bs-toggle="modal"
                    data-bs-target="#subirFotoModal"
                    id="anadirFotoBtn"
                    @(hayUsuarios ? "" : "disabled")>
                Añadir foto
            </button>
        </form>
    </div>

    <div class="col-12 col-lg-3 d-flex justify-content-lg-end">
        <button type="button"
                class="btn btn-success w-100"
                data-bs-toggle="modal"
                data-bs-target="#editarNovedadesModal"
                id="editarNovedadesBtn"
                @(hayUsuarios ? "" : "disabled")>
            Editar novedades
        </button>
    </div>
</div>

@if (hayUsuarios)
{
    <div id="seleccionUsuariosResumen" class="small text-muted mt-2">
        Selecciona un usuario para habilitar las acciones.
    </div>
}

@if (!hayUsuarios)
{
    <div class="alert alert-info mt-3">
        No se encontraron usuarios para mostrar.
    </div>
}
else
{
    <div class="table-responsive mt-3" style="max-height: 60vh; overflow-y: auto;">
        <table class="table table-striped table-bordered mb-0">
            <thead class="table-light">
                <tr>
                    <th class="text-center" style="width: 110px;">
                        <div>Seleccionar</div>
                        <div class="form-check d-inline-flex align-items-center gap-1 mb-0">
                            <input type="checkbox"
                                   class="form-check-input"
                                   id="seleccionarTodosUsuarios"
                                   aria-label="Seleccionar todos los usuarios" />
                            <label class="form-check-label small" for="seleccionarTodosUsuarios">Todo</label>
                        </div>
                    </th>
                    <th>Foto</th>
                    <th>Nombre</th>
                    <th>Cédula</th>
                    <th>Cargo</th>
                    <th>Gerencia</th>
                    <th>Correo</th>
                    <th>Inicio de contrato</th>
                    <th>Finalización contrato</th>
                    <th>Finalización período de prueba</th>
                    <th>Novedades</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var u in Model)
            {
                var fotoUrl = Url.Action("Foto", "Usuarios", new { id = u.Id }) ?? string.Empty;
                <tr>
                    <td class="text-center">
                        <input type="checkbox"
                               class="form-check-input usuario-select"
                               aria-label="Seleccionar usuario"
                               data-id="@u.Id"
                               data-nombre="@u.NombreCompleto"
                               data-novedades="@u.Novedades"
                               data-foto-url="@fotoUrl" />
                    </td>
                    <td class="text-center align-middle">
                        <img src="@fotoUrl"
                             alt="Foto de @u.NombreCompleto"
                             class="ab-user-photo-thumb"
                             loading="lazy" />
                    </td>
                    <td>
                        <a asp-controller="Usuarios"
                           asp-action="Detalle"
                           asp-route-id="@u.Id"
                           class="link-primary text-decoration-none">
                            @u.NombreCompleto
                        </a>
                    </td>
                    <td>@u.Cedula</td>
                    <td>@u.Cargo</td>
                    <td>@u.Gerencia</td>
                    <td>@u.CorreoElectronico</td>
                    <td>@(u.FechaInicioContrato?.ToShortDateString() ?? "-")</td>
                    <td>@(u.FechaFinalizacionContrato?.ToShortDateString() ?? "-")</td>
                    <td>@(u.FechaFinalizacionPeriodoPrueba?.ToShortDateString() ?? "-")</td>
                    <td class="text-wrap">@u.Novedades</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

<div class="modal fade" id="subirFotoModal" tabindex="-1" aria-labelledby="subirFotoLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="SubirFoto" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="cedula" value="@cedulaFiltro" />
                <div class="modal-header">
                    <h5 class="modal-title" id="subirFotoLabel">Añadir foto</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <div class="d-flex flex-column align-items-center text-center gap-3">
                        <img id="fotoUsuarioPreview"
                             alt="Vista previa de la foto actual"
                             class="ab-user-photo-preview d-none" />
                        <div class="w-100">
                            <label class="form-label" for="fotoUsuarioNombre">Usuario</label>
                            <input type="text" id="fotoUsuarioNombre" class="form-control" readonly />
                            <input type="hidden" name="id" id="fotoUsuarioId" />
                        </div>
                    </div>
                    <div class="mt-3">
                        <label for="fotoArchivo" class="form-label">Selecciona la foto</label>
                        <input id="fotoArchivo"
                               name="archivo"
                               type="file"
                               class="form-control"
                               accept=".png,.jpg,.jpeg,image/png,image/jpeg"
                               required />
                        <div class="form-text">
                            La imagen se cargará directamente en Dataverse para el usuario seleccionado.
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Subir foto</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editarNovedadesModal" tabindex="-1" aria-labelledby="editarNovedadesLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="ActualizarNovedades" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="editarNovedadesLabel">Editar novedades</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label" for="novedadesUsuarioNombre">Usuario</label>
                        <input type="text" id="novedadesUsuarioNombre" class="form-control" readonly />
                        <input type="hidden" name="id" id="novedadesUsuarioId" />
                    </div>
                    <div class="mb-3">
                        <label for="novedadesTexto" class="form-label">Novedades</label>
                        <textarea id="novedadesTexto" name="novedades" class="form-control" rows="6"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-success">Guardar novedades</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const checkboxes = document.querySelectorAll('.usuario-select');
            const seleccionarTodos = document.getElementById('seleccionarTodosUsuarios');
            const seleccionResumen = document.getElementById('seleccionUsuariosResumen');
            const iniciarBtn = document.getElementById('iniciarEvaluacionBtn');
            const fotoBtn = document.getElementById('anadirFotoBtn');
            const editarBtn = document.getElementById('editarNovedadesBtn');
            const evalInputId = document.getElementById('usuarioEvaluacionId');
            const fotoInputId = document.getElementById('fotoUsuarioId');
            const fotoInputNombre = document.getElementById('fotoUsuarioNombre');
            const fotoPreview = document.getElementById('fotoUsuarioPreview');
            const inputId = document.getElementById('novedadesUsuarioId');
            const inputNombre = document.getElementById('novedadesUsuarioNombre');
            const textarea = document.getElementById('novedadesTexto');

            const getSelected = () => Array.from(checkboxes).filter((checkbox) => checkbox.checked);

            const setButtonsState = (selectedCount) => {
                const enabled = selectedCount === 1;
                if (iniciarBtn) {
                    iniciarBtn.disabled = !enabled;
                }
                if (fotoBtn) {
                    fotoBtn.disabled = !enabled;
                }
                if (editarBtn) {
                    editarBtn.disabled = !enabled;
                }
            };

            const syncSelectAllState = () => {
                if (!(seleccionarTodos instanceof HTMLInputElement)) {
                    return;
                }

                const selectedCount = getSelected().length;
                seleccionarTodos.checked = checkboxes.length > 0 && selectedCount === checkboxes.length;
                seleccionarTodos.indeterminate = selectedCount > 0 && selectedCount < checkboxes.length;
            };

            const syncSelectionSummary = (selectedCount) => {
                if (!seleccionResumen) {
                    return;
                }

                if (selectedCount === 0) {
                    seleccionResumen.textContent = 'Selecciona un usuario para habilitar las acciones.';
                    return;
                }

                if (selectedCount === 1) {
                    seleccionResumen.textContent = '1 usuario seleccionado.';
                    return;
                }

                seleccionResumen.textContent = `${selectedCount} usuarios seleccionados. Las acciones actuales requieren una sola selección.`;
            };

            const syncFotoPreview = (selected) => {
                if (!fotoInputId || !fotoInputNombre || !fotoPreview) {
                    return;
                }

                if (!selected) {
                    fotoInputId.value = '';
                    fotoInputNombre.value = '';
                    fotoPreview.removeAttribute('src');
                    fotoPreview.classList.add('d-none');
                    return;
                }

                fotoInputId.value = selected.dataset.id || '';
                fotoInputNombre.value = selected.dataset.nombre || '';
                fotoPreview.src = selected.dataset.fotoUrl || '';
                fotoPreview.classList.remove('d-none');
            };

            const updateSelection = () => {
                const selectedItems = getSelected();
                const selectedCount = selectedItems.length;
                const selected = selectedCount === 1 ? selectedItems[0] : null;
                if (!evalInputId || !inputId || !textarea || !inputNombre) {
                    return;
                }

                if (!selected) {
                    evalInputId.value = '';
                    inputId.value = '';
                    inputNombre.value = '';
                    textarea.value = '';
                    syncFotoPreview(null);
                    setButtonsState(selectedCount);
                    syncSelectAllState();
                    syncSelectionSummary(selectedCount);
                    return;
                }

                evalInputId.value = selected.dataset.id || '';
                inputId.value = selected.dataset.id || '';
                inputNombre.value = selected.dataset.nombre || '';
                textarea.value = selected.dataset.novedades || '';
                syncFotoPreview(selected);
                setButtonsState(selectedCount);
                syncSelectAllState();
                syncSelectionSummary(selectedCount);
            };

            checkboxes.forEach((checkbox) => {
                checkbox.addEventListener('change', () => {
                    updateSelection();
                });
            });

            if (seleccionarTodos instanceof HTMLInputElement) {
                seleccionarTodos.addEventListener('change', () => {
                    checkboxes.forEach((checkbox) => {
                        checkbox.checked = seleccionarTodos.checked;
                    });
                    updateSelection();
                });
            }

            updateSelection();
        })();
    </script>
}
