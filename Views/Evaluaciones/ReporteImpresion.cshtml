@using EvaluacionDesempenoAB.ViewModels
@model EvaluacionReporteViewModel

@{
    Layout = null;
    var esCertificadoEnBlanco = ViewBag.EsCertificadoEnBlanco is bool valor && valor;
    var planAccion = esCertificadoEnBlanco
        ? new List<PlanAccionItemVm>()
        : Model.PlanAccion
            .Where(p => !string.IsNullOrWhiteSpace(p.Comportamiento) || !string.IsNullOrWhiteSpace(p.Descripcion))
            .ToList();
    var tituloFormato = esCertificadoEnBlanco && !string.IsNullOrWhiteSpace(Model.TipoFormularioNombre)
        ? $"Formato evaluación de desempeño - {Model.TipoFormularioNombre}"
        : "Formato evaluación de desempeño";
    var nombreArchivo = esCertificadoEnBlanco
        ? "certificado-en-blanco.pdf"
        : $"reporte-evaluacion-{Model.CedulaUsuario}.pdf";
}

@functions {
    private (string Texto, string Clase) ObtenerNivelInfo(int? puntaje)
    {
        if (!puntaje.HasValue)
        {
            return ("Sin puntaje", "bg-secondary");
        }

        if (puntaje.Value <= 25)
        {
            return ("Nunca", "bg-danger");
        }

        if (puntaje.Value <= 50)
        {
            return ("Casi nunca", "bg-warning text-dark");
        }

        if (puntaje.Value <= 75)
        {
            return ("A veces", "bg-info text-dark");
        }

        if (puntaje.Value <= 90)
        {
            return ("Casi siempre", "bg-primary");
        }

        return ("Siempre", "bg-success");
    }

    private static string ValorOBlanco(bool esCertificadoEnBlanco, string? valor)
        => esCertificadoEnBlanco ? string.Empty : valor ?? string.Empty;

    private static string FechaOBlanco(bool esCertificadoEnBlanco, DateTime? fecha)
        => esCertificadoEnBlanco || !fecha.HasValue ? string.Empty : fecha.Value.ToString("dd/MM/yyyy");

    private static string DecimalOBlanco(bool esCertificadoEnBlanco, decimal? valor)
        => esCertificadoEnBlanco || !valor.HasValue ? string.Empty : $"{valor.Value}%";

    private static string EnteroOBlanco(bool esCertificadoEnBlanco, int? valor)
        => esCertificadoEnBlanco || !valor.HasValue ? string.Empty : $"{valor.Value}%";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Reporte de evaluación</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            background: #ffffff;
            color: #1f1f1f;
            font-family: "Raleway", "Poppins", "Segoe UI", sans-serif;
            font-size: 12px;
        }

        .reporte-pdf {
            background: #ffffff;
            padding: 16px 18px 24px;
            border: 1px solid #444;
        }

        .firma-linea {
            border-top: 1px solid #212529;
        }

        .firma-label {
            margin-top: 8px;
        }

        .firma-contenedor {
            min-height: 128px;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            padding: 0 8px;
        }

        .firma-espacio {
            width: 100%;
            height: 76px;
            display: flex;
            align-items: flex-end;
            justify-content: center;
            margin-bottom: 6px;
            padding: 0 8px;
            box-sizing: border-box;
        }

        .firma-imagen {
            max-width: 100%;
            max-height: 100%;
            width: auto;
            height: auto;
            object-fit: scale-down;
            display: block;
            flex: 0 1 auto;
        }

        .firma-nombre {
            margin-top: 4px;
            font-size: 10px;
            font-weight: 600;
            word-break: break-word;
        }

        .tabla-compacta th,
        .tabla-compacta td {
            padding: 4px 6px;
        }

        .tabla-compacta th {
            background: #e6e6e6;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 11px;
            letter-spacing: 0.2px;
        }

        .sheet-title {
            text-transform: uppercase;
            font-weight: 700;
            font-size: 12px;
            text-align: center;
        }

        .sheet-header td,
        .sheet-header th {
            border: 1px solid #444;
            padding: 6px;
            vertical-align: middle;
        }

        .sheet-table {
            width: 100%;
            border-collapse: collapse;
        }

        .sheet-table td,
        .sheet-table th {
            border: 1px solid #444;
        }

        .section-bar {
            background: #f08b3c;
            color: #000;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 11px;
            padding: 4px 8px;
            border: 1px solid #444;
        }

        .section-subtitle {
            font-weight: 600;
            text-transform: uppercase;
            font-size: 11px;
        }

        .rating-cell {
            text-align: center;
            font-weight: 700;
            font-size: 11px;
        }

        .info-label {
            width: 32%;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 10px;
            background: #f4f4f4;
        }

        .info-value {
            font-size: 11px;
        }

        .observaciones-box {
            min-height: 80px;
            padding: 8px;
        }

        .plan-table td {
            vertical-align: top;
        }

        .firmas-table td {
            height: 130px;
            text-align: center;
            vertical-align: bottom;
            padding: 0 12px 10px;
        }

        .firma-evaluado {
            max-width: 420px;
            margin: 0 auto;
        }

        .blank-row td {
            height: 26px;
        }
    </style>
</head>
<body>
<div class="container my-4">
    <div id="reporte-imprimible" class="reporte-pdf shadow-sm">
        <table class="sheet-table sheet-header mb-3">
            <tr>
                <td style="width: 15%; text-align: center;">
                    <img src="~/img/LogoAB.png" alt="Logo AB" style="height: 36px;" />
                </td>
                <td style="width: 55%;">
                    <div class="sheet-title">@tituloFormato</div>
                    <div class="sheet-title">@(esCertificadoEnBlanco ? "" : Model.NombreNivel)</div>
                </td>
                <td style="width: 30%;">
                    <div><strong>Código:</strong> GH-FM-059</div>
                    <div><strong>Versión:</strong> 01</div>
                    <div><strong>Vigencia:</strong> 09-03-2021</div>
                </td>
            </tr>
        </table>

        <div class="section-bar">I. Identificación del colaborador</div>
        <table class="sheet-table tabla-compacta mb-3">
            <tr>
                <td class="info-label">Nombre completo</td>
                <td class="info-value">@ValorOBlanco(esCertificadoEnBlanco, Model.NombreUsuario)</td>
            </tr>
            <tr>
                <td class="info-label">Cédula</td>
                <td class="info-value">@ValorOBlanco(esCertificadoEnBlanco, Model.CedulaUsuario)</td>
            </tr>
            <tr>
                <td class="info-label">Cargo</td>
                <td class="info-value">@ValorOBlanco(esCertificadoEnBlanco, Model.Cargo)</td>
            </tr>
            <tr>
                <td class="info-label">Gerencia</td>
                <td class="info-value">@ValorOBlanco(esCertificadoEnBlanco, Model.Gerencia)</td>
            </tr>
            <tr>
                <td class="info-label">Proyecto</td>
                <td class="info-value">@ValorOBlanco(esCertificadoEnBlanco, Model.Proyecto)</td>
            </tr>
            <tr>
                <td class="info-label">Nombre del jefe inmediato o evaluador</td>
                <td class="info-value">@ValorOBlanco(esCertificadoEnBlanco, Model.NombreJefeInmediatoOEvaluador)</td>
            </tr>
            <tr>
                <td class="info-label">Nombre del evaluador SST</td>
                <td class="info-value">@ValorOBlanco(esCertificadoEnBlanco, Model.NombreEvaluadorSst)</td>
            </tr>
            <tr>
                <td class="info-label">Cargo del evaluador SST</td>
                <td class="info-value">@ValorOBlanco(esCertificadoEnBlanco, Model.CargoEvaluadorSst)</td>
            </tr>
            <tr>
                <td class="info-label">Cargo del jefe inmediato o evaluador</td>
                <td class="info-value">@ValorOBlanco(esCertificadoEnBlanco, Model.CargoJefeInmediatoOEvaluador)</td>
            </tr>
            <tr>
                <td class="info-label">Fecha de ingreso</td>
                <td class="info-value">@FechaOBlanco(esCertificadoEnBlanco, Model.FechaIngreso)</td>
            </tr>
            <tr>
                <td class="info-label">Fecha de evaluación</td>
                <td class="info-value">@FechaOBlanco(esCertificadoEnBlanco, esCertificadoEnBlanco ? null : Model.FechaGeneracionReporte)</td>
            </tr>
            <tr>
                <td class="info-label">Nivel de evaluación</td>
                <td class="info-value">@ValorOBlanco(esCertificadoEnBlanco, Model.NombreNivel)</td>
            </tr>
            <tr>
                <td class="info-label">Promedio general</td>
                <td class="info-value">@DecimalOBlanco(esCertificadoEnBlanco, Model.PromedioGeneral)</td>
            </tr>
        </table>

        <div class="section-bar">II. Detalle por competencia</div>

        @if (esCertificadoEnBlanco)
        {
            @if (!Model.Competencias.Any())
            {
                <div class="section-subtitle mt-3">&nbsp;</div>
                <table class="sheet-table tabla-compacta mb-2">
                    <thead>
                        <tr>
                            <th style="width: 18%;">Competencia</th>
                            <th style="width: 28%;">Comportamiento</th>
                            <th class="rating-cell" style="width: 8%;">Nunca</th>
                            <th class="rating-cell" style="width: 8%;">Casi nunca</th>
                            <th class="rating-cell" style="width: 8%;">A veces</th>
                            <th class="rating-cell" style="width: 8%;">Casi siempre</th>
                            <th class="rating-cell" style="width: 8%;">Siempre</th>
                            <th class="rating-cell" style="width: 14%;">Puntaje</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="blank-row">
                            <td>&nbsp;</td>
                            <td>&nbsp;</td>
                            <td class="rating-cell">&nbsp;</td>
                            <td class="rating-cell">&nbsp;</td>
                            <td class="rating-cell">&nbsp;</td>
                            <td class="rating-cell">&nbsp;</td>
                            <td class="rating-cell">&nbsp;</td>
                            <td class="rating-cell">&nbsp;</td>
                        </tr>
                        <tr>
                            <td colspan="7" class="info-label">Promedio de competencia</td>
                            <td class="rating-cell"><strong>&nbsp;</strong></td>
                        </tr>
                    </tbody>
                </table>
            }
            else
            {
                @foreach (var comp in Model.Competencias)
                {
                    <div class="section-subtitle mt-3">@comp.Nombre</div>
                    <table class="sheet-table tabla-compacta mb-2">
                        <thead>
                            <tr>
                                <th style="width: 18%;">Competencia</th>
                                <th style="width: 28%;">Comportamiento</th>
                                <th class="rating-cell" style="width: 8%;">Nunca</th>
                                <th class="rating-cell" style="width: 8%;">Casi nunca</th>
                                <th class="rating-cell" style="width: 8%;">A veces</th>
                                <th class="rating-cell" style="width: 8%;">Casi siempre</th>
                                <th class="rating-cell" style="width: 8%;">Siempre</th>
                                <th class="rating-cell" style="width: 14%;">Puntaje</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var c in comp.Comportamientos)
                        {
                            <tr>
                                <td>@comp.Nombre</td>
                                <td>@c.Descripcion</td>
                                <td class="rating-cell">&nbsp;</td>
                                <td class="rating-cell">&nbsp;</td>
                                <td class="rating-cell">&nbsp;</td>
                                <td class="rating-cell">&nbsp;</td>
                                <td class="rating-cell">&nbsp;</td>
                                <td class="rating-cell">&nbsp;</td>
                            </tr>
                        }
                        <tr>
                            <td colspan="7" class="info-label">Promedio de competencia</td>
                            <td class="rating-cell"><strong>&nbsp;</strong></td>
                        </tr>
                        </tbody>
                    </table>
                }
            }
        }
        else
        {
            @foreach (var comp in Model.Competencias)
            {
                <div class="section-subtitle mt-3">@comp.Nombre</div>
                <table class="sheet-table tabla-compacta mb-2">
                    <thead>
                        <tr>
                            <th style="width: 18%;">Competencia</th>
                            <th style="width: 28%;">Comportamiento</th>
                            <th class="rating-cell" style="width: 8%;">Nunca</th>
                            <th class="rating-cell" style="width: 8%;">Casi nunca</th>
                            <th class="rating-cell" style="width: 8%;">A veces</th>
                            <th class="rating-cell" style="width: 8%;">Casi siempre</th>
                            <th class="rating-cell" style="width: 8%;">Siempre</th>
                            <th class="rating-cell" style="width: 14%;">Puntaje</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var c in comp.Comportamientos)
                    {
                        var nivelInfo = ObtenerNivelInfo(c.Puntaje);
                        <tr>
                            <td>@comp.Nombre</td>
                            <td>@c.Descripcion</td>
                            <td class="rating-cell">@(nivelInfo.Texto == "Nunca" ? "X" : "")</td>
                            <td class="rating-cell">@(nivelInfo.Texto == "Casi nunca" ? "X" : "")</td>
                            <td class="rating-cell">@(nivelInfo.Texto == "A veces" ? "X" : "")</td>
                            <td class="rating-cell">@(nivelInfo.Texto == "Casi siempre" ? "X" : "")</td>
                            <td class="rating-cell">@(nivelInfo.Texto == "Siempre" ? "X" : "")</td>
                            <td class="rating-cell">@EnteroOBlanco(false, c.Puntaje)</td>
                        </tr>
                    }
                    <tr>
                        <td colspan="7" class="info-label">Promedio de competencia</td>
                        <td class="rating-cell"><strong>@comp.Promedio %</strong></td>
                    </tr>
                    </tbody>
                </table>
            }
        }

        <div class="section-bar mt-3">III. Oportunidades de mejora</div>

        @if (esCertificadoEnBlanco)
        {
            <table class="sheet-table tabla-compacta mt-2">
                <thead>
                    <tr>
                        <th>Competencia</th>
                        <th>Comportamiento</th>
                        <th style="width: 120px;">Puntaje</th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="blank-row">
                        <td>&nbsp;</td>
                        <td>&nbsp;</td>
                        <td class="rating-cell">&nbsp;</td>
                    </tr>
                </tbody>
            </table>
        }
        else if (!Model.OportunidadesMejora.Any())
        {
            <div class="mt-2">No se identificaron comportamientos con puntajes entre 70% y 85%.</div>
        }
        else
        {
            <table class="sheet-table tabla-compacta mt-2">
                <thead>
                    <tr>
                        <th>Competencia</th>
                        <th>Comportamiento</th>
                        <th style="width: 120px;">Puntaje</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var o in Model.OportunidadesMejora)
                {
                    <tr>
                        <td>@o.Competencia</td>
                        <td>@o.Comportamiento</td>
                        <td class="rating-cell">@o.Puntaje %</td>
                    </tr>
                }
                </tbody>
            </table>
        }

        @if (esCertificadoEnBlanco || !string.IsNullOrWhiteSpace(Model.ObservacionesGenerales))
        {
            <div class="section-bar mt-3">IV. Observaciones generales</div>
            <table class="sheet-table tabla-compacta mt-2">
                <tr>
                    <td class="observaciones-box">@(esCertificadoEnBlanco ? "" : Model.ObservacionesGenerales)</td>
                </tr>
            </table>
        }

        <div class="section-bar mt-3">V. Plan de acción</div>
        <div class="mt-2">Define el plan de acción a partir de los resultados de la evaluación y las oportunidades de mejora entre 70% y 85%.</div>

        @if (esCertificadoEnBlanco)
        {
            <table class="sheet-table tabla-compacta plan-table mt-2">
                <thead>
                    <tr>
                        <th style="width: 50%;">Oportunidad de mejora</th>
                        <th style="width: 50%;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="blank-row">
                        <td>&nbsp;</td>
                        <td>&nbsp;</td>
                    </tr>
                    <tr class="blank-row">
                        <td>&nbsp;</td>
                        <td>&nbsp;</td>
                    </tr>
                </tbody>
            </table>
        }
        else if (!planAccion.Any())
        {
            <div class="mt-2">No hay plan de acción registrado.</div>
        }
        else
        {
            <table class="sheet-table tabla-compacta plan-table mt-2">
                <thead>
                    <tr>
                        <th style="width: 50%;">Oportunidad de mejora</th>
                        <th style="width: 50%;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var plan in planAccion)
                {
                    <tr>
                        <td>@plan.Comportamiento</td>
                        <td>@plan.Descripcion</td>
                    </tr>
                }
                </tbody>
            </table>
        }

        <div class="section-bar mt-4">VI. Firmas</div>
        <table class="sheet-table firmas-table mt-2">
            <tr>
                <td style="width: 50%;">
                    <div class="firma-contenedor">
                        <div class="firma-espacio">
                            @if (!esCertificadoEnBlanco && !string.IsNullOrWhiteSpace(Model.FirmaEvaluadorDataUrl))
                            {
                                <img src="@Model.FirmaEvaluadorDataUrl" alt="Firma del evaluador" class="firma-imagen" />
                            }
                        </div>
                        <div class="firma-linea"></div>
                        <div class="firma-label">Firma del evaluador</div>
                        <div class="firma-nombre">@ValorOBlanco(esCertificadoEnBlanco, Model.NombreJefeInmediatoOEvaluador)</div>
                    </div>
                </td>
                <td style="width: 50%;">
                    <div class="firma-contenedor">
                        <div class="firma-espacio">
                            @if (!esCertificadoEnBlanco && !string.IsNullOrWhiteSpace(Model.FirmaEvaluadorSstDataUrl))
                            {
                                <img src="@Model.FirmaEvaluadorSstDataUrl" alt="Firma del evaluador SST" class="firma-imagen" />
                            }
                        </div>
                        <div class="firma-linea"></div>
                        <div class="firma-label">Firma del evaluador SST</div>
                        <div class="firma-nombre">@ValorOBlanco(esCertificadoEnBlanco, Model.NombreEvaluadorSst)</div>
                    </div>
                </td>
            </tr>
            <tr>
                <td colspan="2">
                    <div class="firma-contenedor firma-evaluado">
                        <div class="firma-espacio"></div>
                        <div class="firma-linea"></div>
                        <div class="firma-label">Firma del evaluado</div>
                        <div class="firma-nombre">@ValorOBlanco(esCertificadoEnBlanco, Model.NombreUsuario)</div>
                    </div>
                </td>
            </tr>
        </table>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"
        integrity="sha512-YcsIPGdhPK4P0H8JipdAEGZs4B/UXK5wLkMl1bDqLqngt/5qw+5mFZf2W8yI4KpGpkYp4a9p3KX8bfxiTltj/Q=="
        crossorigin="anonymous"
        referrerpolicy="no-referrer"></script>
<script>
    const esperarImagenes = async (container) => {
        const images = Array.from(container.querySelectorAll("img"));
        const pendientes = images
            .filter((img) => !img.complete)
            .map((img) => new Promise((resolve) => {
                img.addEventListener("load", resolve, { once: true });
                img.addEventListener("error", resolve, { once: true });
            }));

        if (pendientes.length > 0) {
            await Promise.all(pendientes);
        }
    };

    window.addEventListener("load", async () => {
        const reporte = document.getElementById("reporte-imprimible");
        if (!reporte || typeof html2pdf === "undefined") {
            return;
        }

        await esperarImagenes(reporte);

        const opciones = {
            margin: 0.3,
            filename: "@nombreArchivo",
            html2canvas: { scale: 2 },
            jsPDF: { unit: "in", format: "letter", orientation: "portrait" }
        };

        html2pdf().set(opciones).from(reporte).save();
    });
</script>
</body>
</html>
