@using EvaluacionDesempenoAB.ViewModels
@model EvaluacionReporteViewModel

@{
    ViewData["Title"] = "Reporte de evaluacion";
    var opcionesPlanPorCompetencia = Model.OpcionesPlanAccion
        .GroupBy(o => o.Competencia)
        .OrderBy(g => g.Key)
        .ToList();
    var mostrarModalFirma = ViewBag.MostrarModalFirma is bool abrirModal && abrirModal;
    var firmaGuardada = ViewBag.FirmaGuardada is bool firmaOk && firmaOk;
}

@functions {
    private (string Texto, string Clase) ObtenerNivelInfo(int? puntaje)
    {
        if (!puntaje.HasValue)
        {
            return ("Sin puntaje", "bg-secondary");
        }

        if (puntaje.Value <= 25)
        {
            return ("Nunca", "bg-danger");
        }

        if (puntaje.Value <= 50)
        {
            return ("Casi nunca", "bg-warning text-dark");
        }

        if (puntaje.Value <= 75)
        {
            return ("A veces", "bg-info text-dark");
        }

        if (puntaje.Value <= 90)
        {
            return ("Casi siempre", "bg-primary");
        }

        return ("Siempre", "bg-success");
    }
}

<div class="container mt-4">
    <h2>Reporte de evaluacion de desempeno</h2>

    @if (firmaGuardada)
    {
        <div class="alert alert-success mt-3">
            La firma del evaluador se guardo correctamente.
        </div>
    }

    <div id="firma-estado-general" class="alert alert-success mt-3 d-none"></div>

    <div class="card mt-3">
        <div class="card-body">
            <h5 class="card-title">@Model.NombreUsuario (@Model.CedulaUsuario)</h5>
            <p class="card-text mb-1"><strong>Cargo:</strong> @Model.Cargo</p>
            <p class="card-text mb-1"><strong>Gerencia:</strong> @Model.Gerencia</p>
            <p class="card-text mb-1"><strong>Nivel de evaluacion:</strong> @Model.NombreNivel</p>
            <p class="card-text mb-1"><strong>Tipo de evaluacion:</strong> @Model.TipoEvaluacion</p>
            <p class="card-text mb-1"><strong>Fecha de evaluacion:</strong> @Model.FechaEvaluacion.ToShortDateString()</p>
            <p class="card-text mb-1"><strong>Alcance actual:</strong> @Model.AlcanceEvaluadorActual</p>
            <div class="d-flex flex-wrap gap-2 mb-3">
                <span class="badge @(Model.EvaluacionNormalCompleta ? "bg-success" : "bg-secondary")">
                    Evaluacion normal: @(Model.EvaluacionNormalCompleta ? "Completada" : "Pendiente")
                </span>
                <span class="badge @(Model.EvaluacionSstCompleta ? "bg-success" : "bg-secondary")">
                    Evaluacion SST: @(Model.EvaluacionSstCompleta ? "Completada" : "Pendiente")
                </span>
            </div>
            <p class="card-text">
                <strong>Promedio general:</strong>
                @if (Model.PromedioGeneral.HasValue)
                {
                    @Model.PromedioGeneral.Value<span>%</span>
                }
                else
                {
                    <span>No calculado</span>
                }
            </p>
        </div>
    </div>

    @if (!Model.EvaluacionNormalCompleta || !Model.EvaluacionSstCompleta)
    {
        <div class="alert alert-info mt-3">
            El resultado final se calculara cuando la evaluacion normal y la evaluacion SST esten completas.
        </div>
    }

    <h4 class="mt-4">Detalle por competencia</h4>

    @foreach (var comp in Model.Competencias)
    {
        <div class="card mt-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><strong>@comp.Nombre</strong></span>
                <span>Promedio: @comp.Promedio %</span>
            </div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Comportamiento</th>
                            <th style="width: 100px;">Puntaje</th>
                            <th style="width: 140px;">Nivel</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var c in comp.Comportamientos)
                    {
                        <tr class="@(c.Puntaje.HasValue && c.Puntaje.Value < 76 ? "table-warning" : "")">
                            <td>@c.Descripcion</td>
                            <td>
                                @if (c.Puntaje.HasValue)
                                {
                                    @c.Puntaje.Value<span>%</span>
                                }
                            </td>
                            <td>
                                @{
                                    var nivelInfo = ObtenerNivelInfo(c.Puntaje);
                                }
                                <span class="badge @nivelInfo.Clase">@nivelInfo.Texto</span>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <h4 class="mt-4">Oportunidades de mejora</h4>

    @if (!Model.OportunidadesMejora.Any())
    {
        <div class="alert alert-success mt-2">
            No se identificaron comportamientos con puntajes por debajo del 76%.
        </div>
    }
    else
    {
        <table class="table table-bordered mt-2">
            <thead class="table-light">
                <tr>
                    <th>Competencia</th>
                    <th>Comportamiento</th>
                    <th style="width: 120px;">Puntaje</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var o in Model.OportunidadesMejora)
            {
                <tr>
                    <td>@o.Competencia</td>
                    <td>@o.Comportamiento</td>
                    <td>@o.Puntaje %</td>
                </tr>
            }
            </tbody>
        </table>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ObservacionesGenerales))
    {
        <h4 class="mt-4">Observaciones generales</h4>
        <div class="card mt-2">
            <div class="card-body">
                @Model.ObservacionesGenerales
            </div>
        </div>
    }

    <h4 class="mt-4">Plan de accion</h4>

    <p>
        Define el plan de accion para los comportamientos del bloque que te corresponde evaluar.
    </p>

    <form asp-action="GuardarPlanAccion" method="post" class="mt-2">
        @Html.AntiForgeryToken()
        <input asp-for="EvaluacionId" type="hidden" />

        <table class="table table-striped">
            <thead class="table-light">
                <tr>
                    <th style="width: 50%;">Comportamiento</th>
                    <th style="width: 50%;">Acciones</th>
                </tr>
            </thead>
            <tbody id="plan-accion-body">
            @for (int i = 0; i < Model.PlanAccion.Count; i++)
            {
                <tr>
                    <td>
                        <select asp-for="PlanAccion[@i].ComportamientoId" class="form-select plan-accion-comportamiento">
                            <option value="">Seleccione un comportamiento</option>
                            @foreach (var grupo in opcionesPlanPorCompetencia)
                            {
                                <optgroup label="@grupo.Key">
                                    @foreach (var opcion in grupo)
                                    {
                                        <option value="@opcion.ComportamientoId">@opcion.Comportamiento</option>
                                    }
                                </optgroup>
                            }
                            @if (Model.PlanAccion[i].ComportamientoId is Guid comportamientoSeleccionadoId &&
                                 !Model.OpcionesPlanAccion.Any(o => o.ComportamientoId == comportamientoSeleccionadoId))
                            {
                                <option value="@comportamientoSeleccionadoId" selected="selected">
                                    @Model.PlanAccion[i].Comportamiento
                                </option>
                            }
                        </select>
                        <input asp-for="PlanAccion[@i].Id" type="hidden" />
                        <input asp-for="PlanAccion[@i].Comportamiento" type="hidden" />
                    </td>
                    <td>
                        <textarea asp-for="PlanAccion[@i].Descripcion" class="form-control plan-accion-descripcion" maxlength="1000" rows="2"></textarea>
                    </td>
                </tr>
            }
            </tbody>
        </table>

        <div class="mt-3 d-flex flex-wrap gap-2">
            <button type="button" class="btn btn-outline-primary" id="agregar-accion" disabled>Añadir otra oportunidad</button>
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalProximaEvaluacion">
                Guardar plan de accion
            </button>
            @if (Model.PuedeAdjuntarFirmaActual)
            {
                <button type="button" class="btn btn-outline-success" data-bs-toggle="modal" data-bs-target="#modalFirmaEvaluador">
                    Adjuntar firma (@Model.EtiquetaFirmaActual)
                </button>
            }
            <a asp-action="Index" class="btn btn-secondary ms-2">Volver al listado</a>
        </div>

        <div class="modal fade" id="modalProximaEvaluacion" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Fecha estimada de reevaluacion</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <label asp-for="FechaProximaEvaluacion" class="form-label">Selecciona la fecha para reevaluar al usuario</label>
                        <input asp-for="FechaProximaEvaluacion" type="date" class="form-control" required />
                        <span asp-validation-for="FechaProximaEvaluacion" class="text-danger"></span>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Confirmar y guardar</button>
                    </div>
                </div>
            </div>
        </div>
    </form>

    @if (Model.PuedeAdjuntarFirmaActual)
    {
        <div class="modal fade" id="modalFirmaEvaluador" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Adjuntar firma de @Model.EtiquetaFirmaActual</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <p class="mb-3">
                            Adjunta tu firma en formato PNG o JPG. Se guardara en tu usuario y se usara automaticamente
                            cuando se descargue el certificado.
                        </p>
                        <form id="firma-evaluador-form" asp-action="SubirFirmaEvaluador" method="post" enctype="multipart/form-data">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.EvaluacionId" />
                            <label for="archivoFirmaEvaluador" class="form-label">Archivo de firma</label>
                            <input id="archivoFirmaEvaluador"
                                   name="archivo"
                                   type="file"
                                   class="form-control"
                                   accept=".png,.jpg,.jpeg,image/png,image/jpeg"
                                   required />
                        </form>
                        <div id="firma-feedback" class="small mt-3"></div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                        <button type="button" class="btn btn-primary" id="guardar-firma-evaluador">Guardar firma</button>
                    </div>
                </div>
            </div>
        </div>
    }

    <template id="plan-accion-row-template">
        <tr>
            <td>
                <select name="PlanAccion[__index__].ComportamientoId" class="form-select plan-accion-comportamiento">
                    <option value="">Seleccione un comportamiento</option>
                    @foreach (var grupo in opcionesPlanPorCompetencia)
                    {
                        <optgroup label="@grupo.Key">
                            @foreach (var opcion in grupo)
                            {
                                <option value="@opcion.ComportamientoId">@opcion.Comportamiento</option>
                            }
                        </optgroup>
                    }
                </select>
                <input type="hidden" name="PlanAccion[__index__].Id" value="" />
                <input type="hidden" name="PlanAccion[__index__].Comportamiento" value="" />
            </td>
            <td>
                <textarea name="PlanAccion[__index__].Descripcion" class="form-control plan-accion-descripcion" maxlength="1000" rows="2"></textarea>
            </td>
        </tr>
    </template>

    <script>
        (() => {
            const planBody = document.getElementById("plan-accion-body");
            const addButton = document.getElementById("agregar-accion");
            const rowTemplate = document.getElementById("plan-accion-row-template");
            let rowIndex = planBody ? planBody.children.length : 0;
            const hasPlanOptions = @Model.OpcionesPlanAccion.Any().ToString().ToLower();
            const mostrarModalFirma = @mostrarModalFirma.ToString().ToLower();
            const firmaForm = document.getElementById("firma-evaluador-form");
            const guardarFirmaButton = document.getElementById("guardar-firma-evaluador");
            const firmaFeedback = document.getElementById("firma-feedback");
            const firmaEstadoGeneral = document.getElementById("firma-estado-general");
            const firmaModalElement = document.getElementById("modalFirmaEvaluador");
            const firmaModal = firmaModalElement && window.bootstrap
                ? window.bootstrap.Modal.getOrCreateInstance(firmaModalElement)
                : null;

            const updateAddButtonState = () => {
                if (!addButton || !planBody) return;
                if (!hasPlanOptions) {
                    addButton.disabled = true;
                    return;
                }

                const rows = planBody.querySelectorAll("tr");
                if (rows.length === 0) {
                    addButton.disabled = false;
                    return;
                }

                const lastSelect = rows[rows.length - 1].querySelector(".plan-accion-comportamiento");
                addButton.disabled = !lastSelect || !lastSelect.value;
            };

            const syncComportamientoLabel = (row) => {
                if (!(row instanceof HTMLTableRowElement)) return;
                const select = row.querySelector(".plan-accion-comportamiento");
                const hidden = row.querySelector('input[name$=".Comportamiento"]');
                if (!(select instanceof HTMLSelectElement) || !(hidden instanceof HTMLInputElement)) return;
                hidden.value = select.options[select.selectedIndex]?.text ?? "";
            };

            const addRow = () => {
                if (!rowTemplate || !planBody) return;
                const html = rowTemplate.innerHTML.replace(/__index__/g, rowIndex);
                planBody.insertAdjacentHTML("beforeend", html);
                rowIndex += 1;
                syncComportamientoLabel(planBody.lastElementChild);
                updateAddButtonState();
            };

            if (planBody) {
                planBody.querySelectorAll("tr").forEach((row) => syncComportamientoLabel(row));
                planBody.addEventListener("change", (event) => {
                    if (event.target instanceof HTMLSelectElement && event.target.classList.contains("plan-accion-comportamiento")) {
                        syncComportamientoLabel(event.target.closest("tr"));
                        updateAddButtonState();
                    }
                });
            }

            if (addButton) {
                addButton.addEventListener("click", addRow);
            }

            if (guardarFirmaButton && firmaForm instanceof HTMLFormElement) {
                guardarFirmaButton.addEventListener("click", async () => {
                    const archivoInput = firmaForm.querySelector('input[name="archivo"]');
                    if (!(archivoInput instanceof HTMLInputElement) || !archivoInput.files || archivoInput.files.length === 0) {
                        if (firmaFeedback) {
                            firmaFeedback.className = "small mt-3 text-danger";
                            firmaFeedback.textContent = "Selecciona un archivo PNG o JPG antes de guardar.";
                        }
                        return;
                    }

                    guardarFirmaButton.setAttribute("disabled", "disabled");
                    if (firmaFeedback) {
                        firmaFeedback.className = "small mt-3 text-muted";
                        firmaFeedback.textContent = "Guardando firma...";
                    }

                    try {
                        const response = await fetch(firmaForm.action, {
                            method: "POST",
                            body: new FormData(firmaForm),
                            headers: {
                                "X-Requested-With": "XMLHttpRequest"
                            }
                        });

                        const payload = await response.json().catch(() => null);
                        if (!response.ok || !payload?.ok) {
                            throw new Error(payload?.message || "No fue posible guardar la firma.");
                        }

                        if (firmaFeedback) {
                            firmaFeedback.className = "small mt-3 text-success";
                            firmaFeedback.textContent = payload.message || "La firma se guardo correctamente.";
                        }

                        if (firmaEstadoGeneral) {
                            firmaEstadoGeneral.classList.remove("d-none", "alert-danger");
                            firmaEstadoGeneral.classList.add("alert-success");
                            firmaEstadoGeneral.textContent = payload.message || "La firma se guardo correctamente.";
                        }

                        if (firmaModal) {
                            window.setTimeout(() => firmaModal.hide(), 800);
                        }
                    } catch (error) {
                        if (firmaFeedback) {
                            firmaFeedback.className = "small mt-3 text-danger";
                            firmaFeedback.textContent = error instanceof Error
                                ? error.message
                                : "No fue posible guardar la firma.";
                        }

                        if (firmaEstadoGeneral) {
                            firmaEstadoGeneral.classList.remove("d-none", "alert-success");
                            firmaEstadoGeneral.classList.add("alert-danger");
                            firmaEstadoGeneral.textContent = error instanceof Error
                                ? error.message
                                : "No fue posible guardar la firma.";
                        }
                    } finally {
                        guardarFirmaButton.removeAttribute("disabled");
                    }
                });
            }

            if (mostrarModalFirma && firmaModal) {
                firmaModal.show();
            }

            updateAddButtonState();
        })();
    </script>
</div>
