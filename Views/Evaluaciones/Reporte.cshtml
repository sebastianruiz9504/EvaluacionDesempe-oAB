@using EvaluacionDesempenoAB.ViewModels
@model EvaluacionReporteViewModel

@{
    ViewData["Title"] = "Reporte de evaluación";
    var opcionesPlanPorCompetencia = Model.OpcionesPlanAccion
        .GroupBy(o => o.Competencia)
        .OrderBy(g => g.Key)
        .ToList();
    var mostrarModalGuardarPlan = ViewBag.MostrarModalGuardarPlan is bool abrirModal && abrirModal;
    var errorGuardadoPlan = ViewBag.ErrorGuardadoPlan as string;
    var tieneFirmaActualGuardada = !string.IsNullOrWhiteSpace(Model.FirmaActualDataUrl);
    var etiquetaVistaPreviaFirma = Model.EtiquetaFirmaActual == "Evaluador SST"
        ? "Firma del evaluador SST"
        : "Firma del evaluador";
}

@functions {
    private (string Texto, string Clase) ObtenerNivelInfo(int? puntaje)
    {
        if (!puntaje.HasValue)
        {
            return ("Sin puntaje", "bg-secondary");
        }

        if (puntaje.Value <= 25)
        {
            return ("Nunca", "bg-danger");
        }

        if (puntaje.Value <= 50)
        {
            return ("Casi nunca", "bg-warning text-dark");
        }

        if (puntaje.Value <= 75)
        {
            return ("A veces", "bg-info text-dark");
        }

        if (puntaje.Value <= 90)
        {
            return ("Casi siempre", "bg-primary");
        }

        return ("Siempre", "bg-success");
    }

    private bool EsOportunidadMejora(int? puntaje)
    {
        return puntaje.HasValue && puntaje.Value >= 70 && puntaje.Value <= 85;
    }
}

<style>
    .firma-preview-card {
        margin-top: 1rem;
        padding: 1rem;
        border: 1px solid #dee2e6;
        border-radius: 0.75rem;
        background: #f8f9fa;
    }

    .firma-preview-stage {
        width: min(100%, 360px);
        height: 76px;
        margin: 0 auto 6px;
        display: flex;
        align-items: flex-end;
        justify-content: center;
        padding: 0 8px;
        box-sizing: border-box;
        overflow: hidden;
    }

    .firma-preview-image {
        width: 100%;
        height: 100%;
        object-fit: contain;
        object-position: center bottom;
        display: block;
        flex: 0 0 auto;
    }

    .firma-preview-line {
        width: min(100%, 360px);
        margin: 0 auto;
        border-top: 1px solid #212529;
    }

    .firma-preview-label {
        width: min(100%, 360px);
        margin: 8px auto 0;
    }
</style>

<div class="container mt-4">
    <h2>Reporte de evaluación de desempeño</h2>

    <div class="card mt-3">
        <div class="card-body">
            <h5 class="card-title">@Model.NombreUsuario (@Model.CedulaUsuario)</h5>
            <p class="card-text mb-1"><strong>Cargo:</strong> @Model.Cargo</p>
            <p class="card-text mb-1"><strong>Gerencia:</strong> @Model.Gerencia</p>
            <p class="card-text mb-1"><strong>Proyecto:</strong> @(string.IsNullOrWhiteSpace(Model.Proyecto) ? "-" : Model.Proyecto)</p>
            <p class="card-text mb-1"><strong>Nivel de evaluación:</strong> @Model.NombreNivel</p>
            <p class="card-text mb-1"><strong>Tipo de evaluación:</strong> @Model.TipoEvaluacion</p>
            <p class="card-text mb-1"><strong>Fecha de evaluación:</strong> @Model.FechaEvaluacion.ToShortDateString()</p>
            <p class="card-text mb-1"><strong>Alcance actual:</strong> @Model.AlcanceEvaluadorActual</p>
            <div class="d-flex flex-wrap gap-2 mb-3">
                <span class="badge @(Model.EvaluacionNormalCompleta ? "bg-success" : "bg-secondary")">
                    Evaluación normal: @(Model.EvaluacionNormalCompleta ? "Completada" : "Pendiente")
                </span>
                <span class="badge @(Model.EvaluacionSstCompleta ? "bg-success" : "bg-secondary")">
                    Evaluación SST: @(Model.EvaluacionSstCompleta ? "Completada" : "Pendiente")
                </span>
            </div>
            <p class="card-text">
                <strong>Promedio general:</strong>
                @if (Model.PromedioGeneral.HasValue)
                {
                    @Model.PromedioGeneral.Value<span>%</span>
                }
                else
                {
                    <span>No calculado</span>
                }
            </p>
        </div>
    </div>

    @if (!Model.EvaluacionNormalCompleta || !Model.EvaluacionSstCompleta)
    {
        <div class="alert alert-info mt-3">
            El resultado final se calculará cuando la evaluación normal y la evaluación SST estén completas.
        </div>
    }

    <h4 class="mt-4">Detalle por competencia</h4>

    @foreach (var comp in Model.Competencias)
    {
        <div class="card mt-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><strong>@comp.Nombre</strong></span>
                <span>Promedio: @comp.Promedio %</span>
            </div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Comportamiento</th>
                            <th style="width: 100px;">Puntaje</th>
                            <th style="width: 140px;">Nivel</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var c in comp.Comportamientos)
                    {
                        <tr class="@(EsOportunidadMejora(c.Puntaje) ? "table-warning" : "")">
                            <td>@c.Descripcion</td>
                            <td>
                                @if (c.Puntaje.HasValue)
                                {
                                    @c.Puntaje.Value<span>%</span>
                                }
                            </td>
                            <td>
                                @{
                                    var nivelInfo = ObtenerNivelInfo(c.Puntaje);
                                }
                                <span class="badge @nivelInfo.Clase">@nivelInfo.Texto</span>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <h4 class="mt-4">Oportunidades de mejora</h4>

    @if (!Model.OportunidadesMejora.Any())
    {
        <div class="alert alert-success mt-2">
            No se identificaron comportamientos con puntajes entre 70% y 85%.
        </div>
    }
    else
    {
        <table class="table table-bordered mt-2">
            <thead class="table-light">
                <tr>
                    <th>Competencia</th>
                    <th>Comportamiento</th>
                    <th style="width: 120px;">Puntaje</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var o in Model.OportunidadesMejora)
            {
                <tr>
                    <td>@o.Competencia</td>
                    <td>@o.Comportamiento</td>
                    <td>@o.Puntaje %</td>
                </tr>
            }
            </tbody>
        </table>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ObservacionesGenerales))
    {
        <h4 class="mt-4">Observaciones generales</h4>
        <div class="card mt-2">
            <div class="card-body">
                @Model.ObservacionesGenerales
            </div>
        </div>
    }

    <h4 class="mt-4">Plan de acción</h4>

    <p>
        Define el plan de acción para los comportamientos del bloque que te corresponde evaluar y que quedaron entre 70% y 85%.
    </p>

    @if (Model.PlanAccionBloqueado)
    {
        <div class="alert alert-warning mt-2">
            El plan de acción ya fue firmado y quedó bloqueado para cambios.
        </div>
    }

    <form asp-action="GuardarPlanAccion" method="post" enctype="multipart/form-data" class="mt-2">
        @Html.AntiForgeryToken()
        <input asp-for="EvaluacionId" type="hidden" />
        <fieldset class="border-0 p-0" disabled="@(Model.PlanAccionBloqueado ? "disabled" : null)">

        <table class="table table-striped">
            <thead class="table-light">
                <tr>
                    <th style="width: 50%;">Comportamiento</th>
                    <th style="width: 50%;">Acciones</th>
                </tr>
            </thead>
            <tbody id="plan-accion-body">
            @for (int i = 0; i < Model.PlanAccion.Count; i++)
            {
                <tr>
                    <td>
                        <select asp-for="PlanAccion[@i].ComportamientoId" class="form-select plan-accion-comportamiento">
                            <option value="">Seleccione un comportamiento</option>
                            @foreach (var grupo in opcionesPlanPorCompetencia)
                            {
                                <optgroup label="@grupo.Key">
                                    @foreach (var opcion in grupo)
                                    {
                                        <option value="@opcion.ComportamientoId">@opcion.Comportamiento</option>
                                    }
                                </optgroup>
                            }
                            @if (Model.PlanAccion[i].ComportamientoId is Guid comportamientoSeleccionadoId &&
                                 !Model.OpcionesPlanAccion.Any(o => o.ComportamientoId == comportamientoSeleccionadoId))
                            {
                                <option value="@comportamientoSeleccionadoId" selected="selected">
                                    @Model.PlanAccion[i].Comportamiento
                                </option>
                            }
                        </select>
                        <input asp-for="PlanAccion[@i].Id" type="hidden" />
                        <input asp-for="PlanAccion[@i].Comportamiento" type="hidden" />
                    </td>
                    <td>
                        <textarea asp-for="PlanAccion[@i].Descripcion" class="form-control plan-accion-descripcion" maxlength="1000" rows="2"></textarea>
                    </td>
                </tr>
            }
            </tbody>
        </table>

        <div class="mt-3 d-flex flex-wrap gap-2">
            <button type="button" class="btn btn-outline-primary" id="agregar-accion" disabled>Añadir otra oportunidad</button>
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalFirma">
                @(Model.PlanAccionBloqueado ? "Plan de acción firmado" : "Guardar plan de acción")
            </button>
        </div>

        <div class="modal fade" id="modalFirma" tabindex="-1" aria-hidden="true" data-subir-firma-url="@Url.Action("SubirFirmaEvaluador", "Evaluaciones")">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">FIRMA</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        @if (!string.IsNullOrWhiteSpace(errorGuardadoPlan))
                        {
                            <div class="alert alert-danger">
                                @errorGuardadoPlan
                            </div>
                        }

                        @if (Model.PuedeAdjuntarFirmaActual)
                        {
                            <label for="firmaArchivo" class="form-label">Adjunta la firma de @Model.EtiquetaFirmaActual</label>
                            <input id="firmaArchivo"
                                   name="firmaArchivo"
                                   type="file"
                                   class="form-control"
                                   accept=".png,.jpg,.jpeg,image/png,image/jpeg" />
                            <div class="form-text">
                                Puedes guardar la firma para revisar la vista previa antes de confirmar el plan de acción.
                            </div>
                            <button type="button" class="btn btn-outline-primary btn-sm mt-3" id="guardarFirmaModal" disabled>
                                Guardar firma y actualizar vista previa
                            </button>
                            <div id="firmaGuardadoEstado" class="d-none mt-3" role="alert" aria-live="polite"></div>

                            <div class="firma-preview-card @(tieneFirmaActualGuardada ? string.Empty : "d-none")" id="firmaPreviewCard">
                                <div class="fw-semibold mb-2">Vista previa en el certificado</div>
                                <div class="firma-preview-stage">
                                    <img id="firmaPreviewImage"
                                         src="@Model.FirmaActualDataUrl"
                                         alt="Vista previa de la firma en el certificado"
                                         class="firma-preview-image @(tieneFirmaActualGuardada ? string.Empty : "d-none")" />
                                </div>
                                <div class="firma-preview-line"></div>
                                <div class="firma-preview-label">@etiquetaVistaPreviaFirma</div>
                            </div>
                            <div id="firmaPreviewEmpty" class="form-text @(tieneFirmaActualGuardada ? "d-none" : string.Empty)">
                                Aún no hay una firma guardada para mostrar en la vista previa.
                            </div>
                        }
                        else
                        {
                            <div class="text-muted">
                                Confirma el guardado del plan de acción.
                            </div>
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Confirmar y guardar plan</button>
                    </div>
                </div>
            </div>
        </div>
        </fieldset>
        <div class="mt-3">
            <a asp-action="Index" class="btn btn-secondary">Volver al listado</a>
        </div>
    </form>

    <template id="plan-accion-row-template">
        <tr>
            <td>
                <select name="PlanAccion[__index__].ComportamientoId" class="form-select plan-accion-comportamiento">
                    <option value="">Seleccione un comportamiento</option>
                    @foreach (var grupo in opcionesPlanPorCompetencia)
                    {
                        <optgroup label="@grupo.Key">
                            @foreach (var opcion in grupo)
                            {
                                <option value="@opcion.ComportamientoId">@opcion.Comportamiento</option>
                            }
                        </optgroup>
                    }
                </select>
                <input type="hidden" name="PlanAccion[__index__].Id" value="" />
                <input type="hidden" name="PlanAccion[__index__].Comportamiento" value="" />
            </td>
            <td>
                <textarea name="PlanAccion[__index__].Descripcion" class="form-control plan-accion-descripcion" maxlength="1000" rows="2"></textarea>
            </td>
        </tr>
    </template>

    <script>
        (() => {
            const planBody = document.getElementById("plan-accion-body");
            const addButton = document.getElementById("agregar-accion");
            const rowTemplate = document.getElementById("plan-accion-row-template");
            let rowIndex = planBody ? planBody.children.length : 0;
            const hasPlanOptions = @Model.OpcionesPlanAccion.Any().ToString().ToLower();
            const planBloqueado = @Model.PlanAccionBloqueado.ToString().ToLower();
            const mostrarModalGuardarPlan = @mostrarModalGuardarPlan.ToString().ToLower();
            const modalGuardarPlanElement = document.getElementById("modalFirma");
            const modalGuardarPlan = modalGuardarPlanElement && window.bootstrap
                ? window.bootstrap.Modal.getOrCreateInstance(modalGuardarPlanElement)
                : null;
            const guardarPlanForm = modalGuardarPlanElement?.closest("form");
            const tokenInput = guardarPlanForm?.querySelector('input[name="__RequestVerificationToken"]');
            const firmaArchivoInput = document.getElementById("firmaArchivo");
            const guardarFirmaModalButton = document.getElementById("guardarFirmaModal");
            const firmaPreviewCard = document.getElementById("firmaPreviewCard");
            const firmaPreviewImage = document.getElementById("firmaPreviewImage");
            const firmaPreviewEmpty = document.getElementById("firmaPreviewEmpty");
            const firmaGuardadoEstado = document.getElementById("firmaGuardadoEstado");
            const subirFirmaUrl = modalGuardarPlanElement?.dataset.subirFirmaUrl ?? "";
            const firmaActualInicial = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.FirmaActualDataUrl ?? string.Empty));

            const updateAddButtonState = () => {
                if (!addButton || !planBody) return;
                if (planBloqueado || !hasPlanOptions) {
                    addButton.disabled = true;
                    return;
                }

                const rows = planBody.querySelectorAll("tr");
                if (rows.length === 0) {
                    addButton.disabled = false;
                    return;
                }

                const lastSelect = rows[rows.length - 1].querySelector(".plan-accion-comportamiento");
                addButton.disabled = !lastSelect || !lastSelect.value;
            };

            const syncComportamientoLabel = (row) => {
                if (!(row instanceof HTMLTableRowElement)) return;
                const select = row.querySelector(".plan-accion-comportamiento");
                const hidden = row.querySelector('input[name$=".Comportamiento"]');
                if (!(select instanceof HTMLSelectElement) || !(hidden instanceof HTMLInputElement)) return;
                hidden.value = select.options[select.selectedIndex]?.text ?? "";
            };

            const addRow = () => {
                if (!rowTemplate || !planBody) return;
                const html = rowTemplate.innerHTML.replace(/__index__/g, rowIndex);
                planBody.insertAdjacentHTML("beforeend", html);
                rowIndex += 1;
                syncComportamientoLabel(planBody.lastElementChild);
                updateAddButtonState();
            };

            const setFirmaPreview = (src) => {
                const hasSrc = typeof src === "string" && src.trim().length > 0;
                if (firmaPreviewCard) {
                    firmaPreviewCard.classList.toggle("d-none", !hasSrc);
                }

                if (firmaPreviewEmpty) {
                    firmaPreviewEmpty.classList.toggle("d-none", hasSrc);
                }

                if (firmaPreviewImage instanceof HTMLImageElement) {
                    if (hasSrc) {
                        firmaPreviewImage.src = src;
                        firmaPreviewImage.classList.remove("d-none");
                    } else {
                        firmaPreviewImage.removeAttribute("src");
                        firmaPreviewImage.classList.add("d-none");
                    }
                }
            };

            const setFirmaStatus = (message, isError = false) => {
                if (!firmaGuardadoEstado) return;

                if (!message) {
                    firmaGuardadoEstado.textContent = "";
                    firmaGuardadoEstado.className = "d-none mt-3";
                    return;
                }

                firmaGuardadoEstado.textContent = message;
                firmaGuardadoEstado.className = `alert ${isError ? "alert-danger" : "alert-success"} py-2 px-3 mt-3 mb-0`;
            };

            if (planBody) {
                planBody.querySelectorAll("tr").forEach((row) => syncComportamientoLabel(row));
                planBody.addEventListener("change", (event) => {
                    if (event.target instanceof HTMLSelectElement && event.target.classList.contains("plan-accion-comportamiento")) {
                        syncComportamientoLabel(event.target.closest("tr"));
                        updateAddButtonState();
                    }
                });
            }

            if (addButton) {
                addButton.addEventListener("click", addRow);
            }

            if (guardarFirmaModalButton instanceof HTMLButtonElement && firmaArchivoInput instanceof HTMLInputElement) {
                const updateGuardarFirmaState = () => {
                    guardarFirmaModalButton.disabled = !(firmaArchivoInput.files && firmaArchivoInput.files.length > 0);
                };

                firmaArchivoInput.addEventListener("change", () => {
                    setFirmaStatus("");
                    updateGuardarFirmaState();
                });

                guardarFirmaModalButton.addEventListener("click", async () => {
                    const archivo = firmaArchivoInput.files?.[0];
                    if (!archivo) {
                        setFirmaStatus("Selecciona una firma en formato PNG o JPG.", true);
                        updateGuardarFirmaState();
                        return;
                    }

                    if (!(tokenInput instanceof HTMLInputElement) || !tokenInput.value || !subirFirmaUrl) {
                        setFirmaStatus("No fue posible preparar la carga de la firma.", true);
                        return;
                    }

                    guardarFirmaModalButton.disabled = true;
                    firmaArchivoInput.disabled = true;
                    setFirmaStatus("Guardando la firma y actualizando la vista previa...");

                    const formData = new FormData();
                    formData.append("__RequestVerificationToken", tokenInput.value);
                    formData.append("id", "@Model.EvaluacionId");
                    formData.append("archivo", archivo);

                    try {
                        const response = await fetch(subirFirmaUrl, {
                            method: "POST",
                            body: formData,
                            headers: {
                                "X-Requested-With": "XMLHttpRequest"
                            }
                        });
                        const result = await response.json().catch(() => null);

                        if (!response.ok || !result?.ok) {
                            throw new Error(result?.message ?? "No fue posible guardar la firma.");
                        }

                        setFirmaPreview(result.firmaDataUrl ?? "");
                        setFirmaStatus(`${result.message} Revisa la vista previa de abajo; si hace falta, puedes cargar otra imagen.`, false);
                        firmaArchivoInput.value = "";
                    } catch (error) {
                        setFirmaStatus(error instanceof Error ? error.message : "No fue posible guardar la firma.", true);
                    } finally {
                        firmaArchivoInput.disabled = false;
                        updateGuardarFirmaState();
                    }
                });

                updateGuardarFirmaState();
            }

            setFirmaPreview(firmaActualInicial);

            if (mostrarModalGuardarPlan && modalGuardarPlan) {
                modalGuardarPlan.show();
            }

            updateAddButtonState();
        })();
    </script>
</div>
