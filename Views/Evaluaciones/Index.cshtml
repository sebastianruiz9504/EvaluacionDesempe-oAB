@using EvaluacionDesempenoAB.ViewModels
@model IEnumerable<EvaluacionListaViewModel>

@{
    ViewData["Title"] = "Mis evaluaciones";
    var cedulaFiltro = ViewData["CedulaFiltro"] as string;
    var proyectoFiltro = ViewData["ProyectoFiltro"] as string;
    var hayEvaluaciones = Model.Any();
    var esSuperAdmin = ViewBag.EsSuperAdmin is bool valor && valor;
    var puedeEliminarEvaluaciones = ViewBag.PuedeEliminarEvaluaciones is bool valorEliminar && valorEliminar;
    var tiposFormularioCertificado = ViewBag.TiposFormularioCertificado as List<TipoFormularioOpcionViewModel> ?? new();
    var errorCarga = ViewBag.ErrorCargaEvaluaciones as string;
    var advertenciaCarga = ViewBag.AdvertenciaCargaEvaluaciones as string;
    var mensajeImportacion = TempData["MensajeImportacionUsuarios"] as string;
    var errorImportacion = TempData["ErrorImportacionUsuarios"] as string;
}

<h2 class="mt-4">Mis evaluaciones</h2>

@if (!string.IsNullOrWhiteSpace(errorCarga))
{
    <div class="alert alert-warning mt-3" role="alert">
        @errorCarga
    </div>
}

@if (!string.IsNullOrWhiteSpace(advertenciaCarga))
{
    <div class="alert alert-info mt-3" role="alert">
        @advertenciaCarga
    </div>
}

@if (!string.IsNullOrWhiteSpace(mensajeImportacion))
{
    <div class="alert alert-success mt-3" role="alert">
        @mensajeImportacion
    </div>
}

@if (!string.IsNullOrWhiteSpace(errorImportacion))
{
    <div class="alert alert-danger mt-3" role="alert">
        @errorImportacion
    </div>
}

<form method="get" class="row g-2 align-items-end mt-1 mb-2">
    <div class="col-md-4">
        <label class="form-label mb-1" for="cedulaFiltro">Filtrar por cédula</label>
        <input id="cedulaFiltro"
               name="cedula"
               class="form-control"
               value="@cedulaFiltro"
               placeholder="Ej: 1012345678" />
    </div>
    <div class="col-md-4">
        <label class="form-label mb-1" for="proyectoFiltro">Filtrar por proyecto</label>
        <input id="proyectoFiltro"
               name="proyecto"
               class="form-control"
               value="@proyectoFiltro"
               placeholder="Ej: Acueducto Norte" />
    </div>
    <div class="col-md-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Aplicar filtros</button>
        @if (!string.IsNullOrWhiteSpace(cedulaFiltro) || !string.IsNullOrWhiteSpace(proyectoFiltro))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
        }
    </div>
</form>

@if (hayEvaluaciones || esSuperAdmin)
{
    <div class="card mt-3 shadow-sm border-0"
         data-evaluaciones-acciones
         data-base-imprimir="@Url.Action("ImprimirResultados", "Evaluaciones")"
         data-base-estado-certificado="@Url.Action("EstadoCertificado", "Evaluaciones")"
         data-base-carpeta="@Url.Action("CarpetaUsuario", "Evaluaciones")"
         data-base-exportar="@Url.Action("ExportarExcel", "Evaluaciones")"
         data-base-plantilla-certificados="@Url.Action("DescargarPlantillaCertificadosMasivos", "Evaluaciones")"
         data-base-certificados-fechas="@Url.Action("PrepararCertificadosMasivosPorFecha", "Evaluaciones")"
         data-base-certificados-cedulas="@Url.Action("PrepararCertificadosMasivosPorCedulas", "Evaluaciones")"
         data-base-eliminar="@(puedeEliminarEvaluaciones ? Url.Action("Eliminar", "Evaluaciones") : string.Empty)"
         data-base-subir-reporte="@Url.Action("SubirReporteFirmado", "Evaluaciones")"
         data-base-subir-firma="@Url.Action("SubirFirmaEvaluador", "Evaluaciones")">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                @if (hayEvaluaciones)
                {
                    <div class="col-12 col-xxl">
                        <div class="small text-muted text-uppercase fw-semibold mb-2">Selección</div>
                        <div class="d-flex flex-wrap align-items-center gap-3">
                            <div class="form-check mb-0">
                                <input id="seleccionarTodasEvaluaciones"
                                       type="checkbox"
                                       class="form-check-input"
                                       disabled />
                                <label class="form-check-label" for="seleccionarTodasEvaluaciones">
                                    Seleccionar todos
                                </label>
                            </div>
                            <span id="resumenSeleccion" class="text-muted small">
                                No hay evaluaciones seleccionadas.
                            </span>
                        </div>
                    </div>
                    <div class="col-12 col-xxl-auto">
                        <div class="small text-muted text-uppercase fw-semibold mb-2">Acciones individuales</div>
                        <div class="d-flex flex-wrap gap-2">
                            <button id="accionFirmaEvaluador"
                                    type="button"
                                    class="btn btn-primary"
                                    disabled>
                                Subir o actualizar firma
                            </button>
                            <a id="accionImprimir"
                               class="btn btn-sm btn-outline-success disabled"
                               href="#"
                               aria-disabled="true">
                                Imprimir resultados
                            </a>
                            <a id="accionCarpeta"
                               class="btn btn-sm btn-outline-secondary disabled"
                               href="#"
                               aria-disabled="true">
                                Carpeta usuario
                            </a>
                            <button id="accionSubirReporte"
                                    type="button"
                                    class="btn btn-sm btn-outline-primary"
                                    disabled>
                                Subir reporte
                            </button>
                        </div>
                    </div>
                    <div class="col-12 col-xxl-auto">
                        <div class="small text-muted text-uppercase fw-semibold mb-2">Acciones múltiples</div>
                        <div class="d-flex flex-wrap gap-2">
                            <button id="accionExportar"
                                    type="button"
                                    class="btn btn-sm btn-outline-dark"
                                    disabled>
                                Exportar resultados
                            </button>
                            <button id="accionExportarCertificadosMasivos"
                                    type="button"
                                    class="btn btn-sm btn-outline-success">
                                Exportar certificados masivos
                            </button>
                            @if (puedeEliminarEvaluaciones)
                            {
                                <button id="accionEliminar"
                                        type="button"
                                        class="btn btn-sm btn-outline-danger"
                                        disabled>
                                    Eliminar seleccionadas
                                </button>
                            }
                        </div>
                    </div>
                }
                @if (esSuperAdmin)
                {
                    <div class="col-12 col-xxl-auto">
                        <div class="small text-muted text-uppercase fw-semibold mb-2">Usuarios</div>
                        <div class="d-flex flex-wrap align-items-center gap-2">
                            <a asp-action="DescargarPlantillaUsuarios"
                               class="btn btn-sm btn-outline-secondary">
                                Descargar plantilla
                            </a>
                            <form asp-action="ImportarUsuarios"
                                  method="post"
                                  enctype="multipart/form-data"
                                  class="d-flex flex-wrap align-items-center gap-2">
                                @Html.AntiForgeryToken()
                                <input type="file"
                                       name="archivo"
                                       accept=".xlsx"
                                       class="form-control form-control-sm"
                                       style="max-width: 260px;"
                                       required />
                                <button type="submit" class="btn btn-sm btn-outline-primary">
                                    Importar usuarios
                                </button>
                            </form>
                        </div>
                    </div>
                    <div class="col-12 col-xxl-auto">
                        <div class="small text-muted text-uppercase fw-semibold mb-2">Certificados</div>
                        <form method="get"
                              asp-action="CertificadoEnBlanco"
                              class="d-flex flex-wrap align-items-center gap-2">
                            <select name="tipoFormulario"
                                    class="form-select form-select-sm"
                                    style="min-width: 240px;"
                                    required>
                                <option value="">Selecciona tipo de formulario</option>
                                @foreach (var tipo in tiposFormularioCertificado)
                                {
                                    <option value="@tipo.Valor">@tipo.Nombre</option>
                                }
                            </select>
                            <button type="submit" class="btn btn-sm btn-outline-success">
                                Certificado en blanco
                            </button>
                        </form>
                    </div>
                }
            </div>

            @if (hayEvaluaciones)
            {
                <div id="ayudaAccionesEvaluaciones" class="small text-muted mt-3">
                    Selecciona una o varias evaluaciones para habilitar las acciones disponibles.
                </div>
            }
        </div>
    </div>
}

@if (!hayEvaluaciones)
{
    @if (string.IsNullOrWhiteSpace(errorCarga))
    {
        <div class="alert alert-info mt-3">
            No se han registrado evaluaciones aún.
        </div>
    }
}
else
{
    <div class="mt-3">
        <input id="filtroTablaEvaluaciones"
               type="text"
               class="form-control"
               placeholder="Filtrar por proyecto o cédula..." />
    </div>
    <div class="table-responsive mt-3">
        <table id="tablaMisEvaluaciones" class="table table-striped table-bordered align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width: 90px;">Seleccionar</th>
                    <th>ID evaluación</th>
                    <th>Fecha evaluación</th>
                    <th>Próxima evaluación</th>
                    <th>Nombre</th>
                    <th>Cédula</th>
                    <th>Gerencia</th>
                    <th>Proyecto</th>
                    <th>Nivel</th>
                    <th>Tipo</th>
                    <th>Resultado final</th>
                    <th>Evaluación normal</th>
                    <th>Evaluación SST</th>
                    <th>Reporte firmado</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var e in Model.OrderByDescending(x => x.FechaEvaluacion))
            {
                <tr data-evaluacion-id="@e.Id"
                    data-usuario-id="@e.UsuarioId"
                    data-puede-imprimir="@((e.EvaluacionNormalCompleta && e.EvaluacionSstCompleta).ToString().ToLower())"
                    data-proyecto="@e.ProyectoUsuario"
                    data-cedula="@e.CedulaUsuario">
                    <td class="text-center">
                        <input type="checkbox"
                               name="evaluacionesSeleccionadas"
                               class="form-check-input"
                               aria-label="Seleccionar evaluación de @e.NombreUsuario" />
                    </td>
                    <td><code>@e.Id</code></td>
                    <td>@e.FechaEvaluacion.ToShortDateString()</td>
                    <td>
                        @if (e.ProximaEvaluacion.HasValue)
                        {
                            @e.ProximaEvaluacion.Value.ToShortDateString()
                        }
                    </td>
                    <td>@e.NombreUsuario</td>
                    <td>@e.CedulaUsuario</td>
                    <td>@e.GerenciaUsuario</td>
                    <td>@e.ProyectoUsuario</td>
                    <td>
                        @e.NivelNombre
                        @if (!string.IsNullOrWhiteSpace(e.NivelCodigo))
                        {
                            <span class="badge bg-secondary ms-1">@e.NivelCodigo</span>
                        }
                    </td>
                    <td>@e.TipoEvaluacion</td>
                    <td>
                        @if (e.ResultadoFinal.HasValue)
                        {
                            @e.ResultadoFinal.Value.ToString("0.##")<span>%</span>
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </td>
                    <td class="text-center">
                        @if (e.ResultadoEvaluacionNormal.HasValue)
                        {
                            <div class="fw-semibold">@e.ResultadoEvaluacionNormal.Value.ToString("0.##")%</div>
                        }
                        else
                        {
                            <div class="text-muted">-</div>
                        }

                        <span class="badge @(e.EvaluacionNormalCompleta ? "bg-success" : "bg-secondary") mt-1">
                            @(e.EvaluacionNormalCompleta ? "Completada" : "Pendiente")
                        </span>
                    </td>
                    <td class="text-center">
                        @if (e.ResultadoEvaluacionSst.HasValue)
                        {
                            <div class="fw-semibold">@e.ResultadoEvaluacionSst.Value.ToString("0.##")%</div>
                        }
                        else
                        {
                            <div class="text-muted">-</div>
                        }

                        <span class="badge @(e.EvaluacionSstCompleta ? "bg-success" : "bg-secondary") mt-1">
                            @(e.EvaluacionSstCompleta ? "Completada" : "Pendiente")
                        </span>
                    </td>
                    <td class="reporte-firmado-cell">
                        @if (e.TieneReporteFirmado)
                        {
                            <a class="reporte-firmado-link"
                               href="@Url.Action("DescargarReporteFirmado", "Evaluaciones", new { id = e.Id })"
                               data-file-name="@e.ReporteFirmadoNombre">
                                @e.ReporteFirmadoNombre
                            </a>
                        }
                        else
                        {
                            <span class="text-muted reporte-firmado-empty">Sin adjunto</span>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

<form id="subirReporteFirmadoToken" method="post" class="d-none">
    @Html.AntiForgeryToken()
</form>
<form id="subirFirmaCertificadoToken" method="post" class="d-none">
    @Html.AntiForgeryToken()
</form>
<form id="exportarExcelToken" method="post" class="d-none">
    @Html.AntiForgeryToken()
</form>
<form id="exportarCertificadosMasivosToken" method="post" class="d-none">
    @Html.AntiForgeryToken()
</form>
<form id="eliminarEvaluacionesToken" method="post" class="d-none">
    @Html.AntiForgeryToken()
</form>
<input id="archivoReporteFirmadoInput"
       type="file"
       class="d-none"
       accept=".pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg" />

<div class="modal fade" id="modalFirmaCertificado" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Subir firma</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <p id="textoFirmaCertificado" class="text-muted mb-3">
                    Adjunta tu firma para emitir el certificado.
                </p>
                <label for="firmaCertificadoArchivo" class="form-label">Firma en PNG o JPG</label>
                <input id="firmaCertificadoArchivo"
                       type="file"
                       class="form-control"
                       accept=".png,.jpg,.jpeg,image/png,image/jpeg" />
                <div id="estadoFirmaCertificado" class="form-text mt-2"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button id="guardarFirmaCertificado" type="button" class="btn btn-primary">
                    Guardar firma y emitir
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalFirmaFaltanteOtro" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Firma pendiente</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <p id="firmaFaltanteOtroMensaje" class="mb-0">
                    Aún falta la firma del otro evaluador.
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Entendido</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalExportandoResultados" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Exportando resultados</h5>
            </div>
            <div class="modal-body">
                <p id="textoEstadoExportacion" class="mb-2 text-muted">Preparando exportación...</p>
                <div class="progress" role="progressbar" aria-label="Progreso de exportación" aria-valuemin="0" aria-valuemax="100">
                    <div id="barraProgresoExportacion"
                         class="progress-bar progress-bar-striped progress-bar-animated"
                         style="width: 0%;">
                        0%
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalCertificadosMasivos" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Exportar certificados masivos</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <ul class="nav nav-tabs" id="certificadosMasivosTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active"
                                id="certificados-fechas-tab"
                                data-bs-toggle="tab"
                                data-bs-target="#certificados-fechas"
                                type="button"
                                role="tab">
                            Por fechas
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link"
                                id="certificados-cedulas-tab"
                                data-bs-toggle="tab"
                                data-bs-target="#certificados-cedulas"
                                type="button"
                                role="tab">
                            Por plantilla
                        </button>
                    </li>
                </ul>
                <div class="tab-content pt-3">
                    <div class="tab-pane fade show active" id="certificados-fechas" role="tabpanel" aria-labelledby="certificados-fechas-tab">
                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <label for="certificadosFechaInicio" class="form-label">Fecha inicial</label>
                                <input id="certificadosFechaInicio" type="date" class="form-control" />
                            </div>
                            <div class="col-12 col-md-6">
                                <label for="certificadosFechaFin" class="form-label">Fecha final</label>
                                <input id="certificadosFechaFin" type="date" class="form-control" />
                            </div>
                        </div>
                        <div class="d-flex justify-content-end mt-3">
                            <button id="descargarCertificadosFechas" type="button" class="btn btn-primary">
                                Descargar por fechas
                            </button>
                        </div>
                    </div>
                    <div class="tab-pane fade" id="certificados-cedulas" role="tabpanel" aria-labelledby="certificados-cedulas-tab">
                        <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
                            <a id="descargarPlantillaCertificados" class="btn btn-outline-secondary" href="#">
                                Descargar plantilla
                            </a>
                            <span class="text-muted small">La plantilla debe conservar solo la columna Cedula.</span>
                        </div>
                        <label for="certificadosArchivoCedulas" class="form-label">Plantilla de cédulas</label>
                        <input id="certificadosArchivoCedulas"
                               type="file"
                               class="form-control"
                               accept=".xlsx" />
                        <div class="d-flex justify-content-end mt-3">
                            <button id="descargarCertificadosCedulas" type="button" class="btn btn-primary">
                                Descargar por plantilla
                            </button>
                        </div>
                    </div>
                </div>
                <div id="estadoCertificadosMasivos" class="form-text mt-3"></div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalDescargandoCertificados" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Descargando certificados</h5>
            </div>
            <div class="modal-body">
                <p id="textoEstadoDescargaCertificados" class="mb-2 text-muted">Preparando certificados...</p>
                <div class="progress" role="progressbar" aria-label="Progreso de descarga de certificados" aria-valuemin="0" aria-valuemax="100">
                    <div id="barraProgresoDescargaCertificados"
                         class="progress-bar progress-bar-striped progress-bar-animated"
                         style="width: 0%;">
                        0%
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <script>
        (() => {
            const tabla = document.getElementById("tablaMisEvaluaciones");
            const acciones = document.querySelector("[data-evaluaciones-acciones]");
            const filtroTablaEvaluaciones = document.getElementById("filtroTablaEvaluaciones");
            const selectorTodasEvaluaciones = document.getElementById("seleccionarTodasEvaluaciones");
            const resumenSeleccion = document.getElementById("resumenSeleccion");
            const ayudaAccionesEvaluaciones = document.getElementById("ayudaAccionesEvaluaciones");
            const accionFirmaEvaluador = document.getElementById("accionFirmaEvaluador");
            const accionImprimir = document.getElementById("accionImprimir");
            const accionCarpeta = document.getElementById("accionCarpeta");
            const accionExportar = document.getElementById("accionExportar");
            const accionExportarCertificadosMasivos = document.getElementById("accionExportarCertificadosMasivos");
            const accionEliminar = document.getElementById("accionEliminar");
            const accionSubirReporte = document.getElementById("accionSubirReporte");
            const archivoReporteFirmadoInput = document.getElementById("archivoReporteFirmadoInput");
            const barraProgresoExportacion = document.getElementById("barraProgresoExportacion");
            const textoEstadoExportacion = document.getElementById("textoEstadoExportacion");
            const barraProgresoDescargaCertificados = document.getElementById("barraProgresoDescargaCertificados");
            const textoEstadoDescargaCertificados = document.getElementById("textoEstadoDescargaCertificados");
            const baseImprimir = acciones?.dataset.baseImprimir ?? "";
            const baseEstadoCertificado = acciones?.dataset.baseEstadoCertificado ?? "";
            const baseCarpeta = acciones?.dataset.baseCarpeta ?? "";
            const baseExportar = acciones?.dataset.baseExportar ?? "";
            const basePlantillaCertificados = acciones?.dataset.basePlantillaCertificados ?? "";
            const baseCertificadosFechas = acciones?.dataset.baseCertificadosFechas ?? "";
            const baseCertificadosCedulas = acciones?.dataset.baseCertificadosCedulas ?? "";
            const baseEliminar = acciones?.dataset.baseEliminar ?? "";
            const baseSubirReporte = acciones?.dataset.baseSubirReporte ?? "";
            const baseSubirFirma = acciones?.dataset.baseSubirFirma ?? "";
            const firmaCertificadoArchivo = document.getElementById("firmaCertificadoArchivo");
            const guardarFirmaCertificado = document.getElementById("guardarFirmaCertificado");
            const textoFirmaCertificado = document.getElementById("textoFirmaCertificado");
            const estadoFirmaCertificado = document.getElementById("estadoFirmaCertificado");
            const firmaFaltanteOtroMensaje = document.getElementById("firmaFaltanteOtroMensaje");
            const certificadosFechaInicio = document.getElementById("certificadosFechaInicio");
            const certificadosFechaFin = document.getElementById("certificadosFechaFin");
            const certificadosArchivoCedulas = document.getElementById("certificadosArchivoCedulas");
            const descargarPlantillaCertificados = document.getElementById("descargarPlantillaCertificados");
            const descargarCertificadosFechas = document.getElementById("descargarCertificadosFechas");
            const descargarCertificadosCedulas = document.getElementById("descargarCertificadosCedulas");
            const estadoCertificadosMasivos = document.getElementById("estadoCertificadosMasivos");
            const tokenExportarInput = document.querySelector('#exportarExcelToken input[name="__RequestVerificationToken"]');
            const tokenCertificadosMasivosInput = document.querySelector('#exportarCertificadosMasivosToken input[name="__RequestVerificationToken"]');
            const tokenEliminarInput = document.querySelector('#eliminarEvaluacionesToken input[name="__RequestVerificationToken"]');
            const tokenFirmaInput = document.querySelector('#subirFirmaCertificadoToken input[name="__RequestVerificationToken"]');
            const modalExportarElement = document.getElementById("modalExportandoResultados");
            const modalExportar = modalExportarElement && window.bootstrap?.Modal
                ? new window.bootstrap.Modal(modalExportarElement, { backdrop: "static", keyboard: false })
                : null;
            const modalFirmaCertificadoElement = document.getElementById("modalFirmaCertificado");
            const modalFirmaCertificado = modalFirmaCertificadoElement && window.bootstrap?.Modal
                ? window.bootstrap.Modal.getOrCreateInstance(modalFirmaCertificadoElement)
                : null;
            const modalFirmaFaltanteOtroElement = document.getElementById("modalFirmaFaltanteOtro");
            const modalFirmaFaltanteOtro = modalFirmaFaltanteOtroElement && window.bootstrap?.Modal
                ? window.bootstrap.Modal.getOrCreateInstance(modalFirmaFaltanteOtroElement)
                : null;
            const modalCertificadosMasivosElement = document.getElementById("modalCertificadosMasivos");
            const modalCertificadosMasivos = modalCertificadosMasivosElement && window.bootstrap?.Modal
                ? window.bootstrap.Modal.getOrCreateInstance(modalCertificadosMasivosElement)
                : null;
            const modalDescargandoCertificadosElement = document.getElementById("modalDescargandoCertificados");
            const modalDescargandoCertificados = modalDescargandoCertificadosElement && window.bootstrap?.Modal
                ? new window.bootstrap.Modal(modalDescargandoCertificadosElement, { backdrop: "static", keyboard: false })
                : null;
            let exportandoEnCurso = false;
            let descargandoCertificadosEnCurso = false;
            let progresoExportacion = 0;
            let intervaloProgresoExportacion = null;
            let evaluacionFirmaCertificadoId = "";
            let modoFirmaCertificado = "emitir";

            if (!tabla || !acciones) {
                return;
            }

            const setDisabled = (element, disabled) => {
                if (!element) {
                    return;
                }

                element.classList.toggle("disabled", disabled);
                element.setAttribute("aria-disabled", disabled ? "true" : "false");

                if (disabled) {
                    element.setAttribute("href", "#");
                }
            };

            const setExportDisabled = (disabled) => {
                if (accionExportar instanceof HTMLButtonElement) {
                    accionExportar.disabled = disabled;
                }
            };

            const setDeleteDisabled = (disabled) => {
                if (accionEliminar instanceof HTMLButtonElement) {
                    accionEliminar.disabled = disabled;
                }
            };

            const setUploadDisabled = (disabled) => {
                if (accionSubirReporte instanceof HTMLButtonElement) {
                    accionSubirReporte.disabled = disabled;
                }
            };

            const setSignatureDisabled = (disabled) => {
                if (accionFirmaEvaluador instanceof HTMLButtonElement) {
                    accionFirmaEvaluador.disabled = disabled;
                }
            };

            const getCheckboxesVisibles = () =>
                Array.from(tabla.querySelectorAll("tbody tr"))
                    .filter((row) => row instanceof HTMLTableRowElement && row.style.display !== "none")
                    .map((row) => row.querySelector("input[name='evaluacionesSeleccionadas']"))
                    .filter((input) => input instanceof HTMLInputElement);

            const getFilasSeleccionadas = () =>
                Array.from(tabla.querySelectorAll("tbody tr"))
                    .filter((row) => row instanceof HTMLTableRowElement && row.style.display !== "none")
                    .filter((row) => {
                        const input = row.querySelector("input[name='evaluacionesSeleccionadas']");
                        return input instanceof HTMLInputElement && input.checked;
                    });

            const getIdsSeleccionados = () =>
                getFilasSeleccionadas()
                    .map((row) => row.dataset.evaluacionId)
                    .filter((id) => !!id);

            const updateSelectionState = (selectedRows) => {
                const visibles = getCheckboxesVisibles();
                const seleccionadas = selectedRows.length;

                if (resumenSeleccion) {
                    if (!visibles.length) {
                        resumenSeleccion.textContent = "No hay evaluaciones visibles para seleccionar.";
                    } else if (!seleccionadas) {
                        resumenSeleccion.textContent = "No hay evaluaciones seleccionadas.";
                    } else if (seleccionadas === 1) {
                        resumenSeleccion.textContent = "1 evaluación seleccionada.";
                    } else {
                        resumenSeleccion.textContent = `${seleccionadas} evaluaciones seleccionadas.`;
                    }
                }

                if (selectorTodasEvaluaciones instanceof HTMLInputElement) {
                    const totalVisibles = visibles.length;
                    const totalSeleccionadas = visibles.filter((input) => input.checked).length;
                    selectorTodasEvaluaciones.disabled = totalVisibles === 0;
                    selectorTodasEvaluaciones.checked = totalVisibles > 0 && totalSeleccionadas === totalVisibles;
                    selectorTodasEvaluaciones.indeterminate = totalSeleccionadas > 0 && totalSeleccionadas < totalVisibles;
                }

                if (ayudaAccionesEvaluaciones) {
                    if (!seleccionadas) {
                        ayudaAccionesEvaluaciones.textContent = "Selecciona una o varias evaluaciones para habilitar las acciones disponibles.";
                    } else if (seleccionadas === 1) {
                        ayudaAccionesEvaluaciones.textContent = "Con una evaluación seleccionada puedes abrir su carpeta, adjuntar reporte y, si ambas partes completaron, imprimir el certificado.";
                    } else {
                        ayudaAccionesEvaluaciones.textContent = "Con varias evaluaciones seleccionadas puedes exportar; las demás acciones requieren una sola evaluación.";
                    }
                }
            };

            const updateLinks = () => {
                const selectedRows = getFilasSeleccionadas();
                updateSelectionState(selectedRows);
                const row = selectedRows.length === 1 ? selectedRows[0] : null;

                setExportDisabled(selectedRows.length === 0);
                setDeleteDisabled(selectedRows.length === 0);

                if (!row) {
                    setDisabled(accionImprimir, true);
                    setDisabled(accionCarpeta, true);
                    setSignatureDisabled(true);
                    setUploadDisabled(true);
                    return;
                }

                const evaluacionId = row.dataset.evaluacionId;
                const usuarioId = row.dataset.usuarioId;
                const puedeImprimir = row.dataset.puedeImprimir === "true";

                accionImprimir.href = puedeImprimir ? `${baseImprimir}?id=${evaluacionId}` : "#";
                accionCarpeta.href = `${baseCarpeta}?usuarioId=${usuarioId}`;

                setDisabled(accionImprimir, !puedeImprimir);
                setDisabled(accionCarpeta, false);
                setSignatureDisabled(false);
                setUploadDisabled(false);
            };

            const getSelectedEvaluacionId = () => {
                const filasSeleccionadas = getFilasSeleccionadas();
                return filasSeleccionadas.length === 1
                    ? filasSeleccionadas[0].dataset.evaluacionId ?? ""
                    : "";
            };

            const mostrarEstadoFirma = (mensaje, esError = false) => {
                if (!estadoFirmaCertificado) {
                    return;
                }

                estadoFirmaCertificado.textContent = mensaje;
                estadoFirmaCertificado.className = esError
                    ? "form-text mt-2 text-danger"
                    : "form-text mt-2 text-success";
            };

            const fetchJson = async (url, options = {}) => {
                const response = await fetch(url, options);
                const contentType = response.headers.get("content-type") ?? "";
                const data = contentType.includes("application/json")
                    ? await response.json()
                    : { message: await response.text() };

                if (!response.ok) {
                    const message = data?.message || "No fue posible completar la solicitud.";
                    throw new Error(message);
                }

                return data;
            };

            const descargarArchivo = (blob, fileName) => {
                const enlace = document.createElement("a");
                const fileUrl = window.URL.createObjectURL(blob);
                enlace.href = fileUrl;
                enlace.download = fileName;
                document.body.appendChild(enlace);
                enlace.click();
                enlace.remove();
                window.URL.revokeObjectURL(fileUrl);
            };

            const mostrarEstadoCertificadosMasivos = (mensaje, esError = false) => {
                if (!estadoCertificadosMasivos) {
                    return;
                }

                estadoCertificadosMasivos.textContent = mensaje;
                estadoCertificadosMasivos.className = esError
                    ? "form-text mt-3 text-danger"
                    : "form-text mt-3 text-success";
            };

            const actualizarProgresoCertificados = (porcentaje, mensaje) => {
                const progreso = Math.max(0, Math.min(100, Math.round(porcentaje)));
                if (barraProgresoDescargaCertificados instanceof HTMLDivElement) {
                    barraProgresoDescargaCertificados.style.width = `${progreso}%`;
                    barraProgresoDescargaCertificados.textContent = `${progreso}%`;
                }

                if (textoEstadoDescargaCertificados) {
                    textoEstadoDescargaCertificados.textContent = mensaje;
                }
            };

            const cargarScriptUnaVez = (src) => new Promise((resolve, reject) => {
                const existente = document.querySelector(`script[src="${src}"]`);
                if (existente) {
                    existente.addEventListener("load", resolve, { once: true });
                    existente.addEventListener("error", reject, { once: true });
                    if (existente.dataset.loaded === "true") {
                        resolve();
                    }
                    return;
                }

                const script = document.createElement("script");
                script.src = src;
                script.async = true;
                script.onload = () => {
                    script.dataset.loaded = "true";
                    resolve();
                };
                script.onerror = reject;
                document.head.appendChild(script);
            });

            const asegurarLibreriasCertificados = async () => {
                if (typeof window.html2pdf === "undefined") {
                    await cargarScriptUnaVez("https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js");
                }

                if (typeof window.JSZip === "undefined") {
                    await cargarScriptUnaVez("https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js");
                }

                if (typeof window.html2pdf === "undefined" || typeof window.JSZip === "undefined") {
                    throw new Error("No fue posible cargar las librerías de generación de certificados.");
                }
            };

            const esperarImagenesDocumento = async (doc) => {
                const images = Array.from(doc.querySelectorAll("img"));
                const pendientes = images
                    .filter((img) => !img.complete)
                    .map((img) => new Promise((resolve) => {
                        img.addEventListener("load", resolve, { once: true });
                        img.addEventListener("error", resolve, { once: true });
                    }));

                if (pendientes.length > 0) {
                    await Promise.all(pendientes);
                }
            };

            const generarPdfCertificado = (certificado) => new Promise((resolve, reject) => {
                const iframe = document.createElement("iframe");
                iframe.style.position = "fixed";
                iframe.style.left = "-10000px";
                iframe.style.top = "0";
                iframe.style.width = "900px";
                iframe.style.height = "1200px";
                iframe.style.opacity = "0";
                iframe.setAttribute("aria-hidden", "true");

                const limpiar = () => {
                    iframe.remove();
                };

                iframe.onload = async () => {
                    try {
                        const doc = iframe.contentDocument;
                        if (!doc) {
                            throw new Error("No fue posible cargar el certificado.");
                        }

                        await esperarImagenesDocumento(doc);
                        await new Promise((resolveTimeout) => window.setTimeout(resolveTimeout, 250));

                        const reporte = doc.getElementById("reporte-imprimible");
                        if (!reporte) {
                            throw new Error("No se encontró el contenido imprimible del certificado.");
                        }

                        const blob = await window.html2pdf()
                            .set({
                                margin: 0.3,
                                filename: certificado.fileName || "certificado.pdf",
                                html2canvas: { scale: 2, useCORS: true },
                                jsPDF: { unit: "in", format: "letter", orientation: "portrait" }
                            })
                            .from(reporte)
                            .outputPdf("blob");

                        limpiar();
                        resolve(blob);
                    } catch (error) {
                        limpiar();
                        reject(error);
                    }
                };

                iframe.onerror = () => {
                    limpiar();
                    reject(new Error("No fue posible cargar el certificado."));
                };

                document.body.appendChild(iframe);
                iframe.src = certificado.url;
            });

            const getNombreUnicoZip = (fileName, usados) => {
                const nombre = fileName || "certificado.pdf";
                if (!usados.has(nombre.toLowerCase())) {
                    usados.add(nombre.toLowerCase());
                    return nombre;
                }

                const punto = nombre.lastIndexOf(".");
                const base = punto > 0 ? nombre.slice(0, punto) : nombre;
                const extension = punto > 0 ? nombre.slice(punto) : ".pdf";
                let contador = 2;
                let candidato = `${base}-${contador}${extension}`;

                while (usados.has(candidato.toLowerCase())) {
                    contador++;
                    candidato = `${base}-${contador}${extension}`;
                }

                usados.add(candidato.toLowerCase());
                return candidato;
            };

            const descargarZipCertificados = async (certificados, omitidos = []) => {
                if (descargandoCertificadosEnCurso) {
                    return;
                }

                descargandoCertificadosEnCurso = true;
                modalCertificadosMasivos?.hide();
                modalDescargandoCertificados?.show();
                actualizarProgresoCertificados(2, "Preparando descarga de certificados...");

                try {
                    await asegurarLibreriasCertificados();
                    const zip = new window.JSZip();
                    const usados = new Set();
                    const total = certificados.length;

                    for (let index = 0; index < total; index++) {
                        const certificado = certificados[index];
                        const porcentajeBase = 5 + Math.floor((index / total) * 80);
                        actualizarProgresoCertificados(
                            porcentajeBase,
                            `Generando certificado ${index + 1} de ${total}...`);

                        const blob = await generarPdfCertificado(certificado);
                        zip.file(getNombreUnicoZip(certificado.fileName, usados), blob);

                        actualizarProgresoCertificados(
                            5 + Math.floor(((index + 1) / total) * 80),
                            `Certificado ${index + 1} de ${total} agregado al ZIP.`);
                    }

                    actualizarProgresoCertificados(90, "Comprimiendo certificados...");
                    const zipBlob = await zip.generateAsync(
                        { type: "blob" },
                        (metadata) => {
                            actualizarProgresoCertificados(
                                90 + Math.floor((metadata.percent || 0) / 10),
                                "Comprimiendo certificados...");
                        });

                    actualizarProgresoCertificados(100, "Descarga lista.");
                    const fileName = `certificados-masivos-${new Date().toISOString().slice(0, 19).replace(/[:T]/g, "_")}.zip`;
                    descargarArchivo(zipBlob, fileName);

                    if (omitidos.length > 0) {
                        const resumenOmitidos = omitidos
                            .slice(0, 8)
                            .map((item) => `${item.referencia}: ${item.motivo}`)
                            .join("\n");
                        const sufijo = omitidos.length > 8
                            ? `\n... y ${omitidos.length - 8} registros más.`
                            : "";

                        window.alert(`ZIP generado. Registros omitidos:\n${resumenOmitidos}${sufijo}`);
                    }
                } catch (error) {
                    window.alert(error instanceof Error
                        ? error.message
                        : "No fue posible generar el ZIP de certificados.");
                    throw error;
                } finally {
                    descargandoCertificadosEnCurso = false;
                    window.setTimeout(() => {
                        modalDescargandoCertificados?.hide();
                    }, 700);
                }
            };

            const procesarRespuestaCertificados = async (data) => {
                const certificados = Array.isArray(data?.certificados) ? data.certificados : [];
                const omitidos = Array.isArray(data?.omitidos) ? data.omitidos : [];

                if (!certificados.length) {
                    throw new Error(data?.message || "No hay certificados listos para descargar.");
                }

                mostrarEstadoCertificadosMasivos(data?.message || "Certificados preparados.", false);
                await descargarZipCertificados(certificados, omitidos);
            };

            const prepararCertificadosPorFechas = async () => {
                if (!(certificadosFechaInicio instanceof HTMLInputElement) ||
                    !(certificadosFechaFin instanceof HTMLInputElement) ||
                    !(tokenCertificadosMasivosInput instanceof HTMLInputElement) ||
                    !baseCertificadosFechas) {
                    return;
                }

                if (!certificadosFechaInicio.value || !certificadosFechaFin.value) {
                    mostrarEstadoCertificadosMasivos("Selecciona fecha inicial y fecha final.", true);
                    return;
                }

                const formData = new FormData();
                formData.append("fechaInicio", certificadosFechaInicio.value);
                formData.append("fechaFin", certificadosFechaFin.value);

                const textoOriginal = descargarCertificadosFechas instanceof HTMLButtonElement
                    ? descargarCertificadosFechas.textContent
                    : "Descargar por fechas";

                if (descargarCertificadosFechas instanceof HTMLButtonElement) {
                    descargarCertificadosFechas.disabled = true;
                    descargarCertificadosFechas.textContent = "Preparando...";
                }

                try {
                    mostrarEstadoCertificadosMasivos("Buscando certificados en el rango seleccionado...", false);
                    const data = await fetchJson(baseCertificadosFechas, {
                        method: "POST",
                        headers: {
                            "RequestVerificationToken": tokenCertificadosMasivosInput.value,
                            "X-Requested-With": "XMLHttpRequest"
                        },
                        body: formData
                    });

                    await procesarRespuestaCertificados(data);
                } catch (error) {
                    mostrarEstadoCertificadosMasivos(
                        error instanceof Error ? error.message : "No fue posible preparar los certificados.",
                        true);
                } finally {
                    if (descargarCertificadosFechas instanceof HTMLButtonElement) {
                        descargarCertificadosFechas.disabled = false;
                        descargarCertificadosFechas.textContent = textoOriginal ?? "Descargar por fechas";
                    }
                }
            };

            const prepararCertificadosPorCedulas = async () => {
                if (!(certificadosArchivoCedulas instanceof HTMLInputElement) ||
                    !(tokenCertificadosMasivosInput instanceof HTMLInputElement) ||
                    !baseCertificadosCedulas) {
                    return;
                }

                const file = certificadosArchivoCedulas.files?.[0];
                if (!(file instanceof File)) {
                    mostrarEstadoCertificadosMasivos("Adjunta la plantilla de Excel con la columna Cedula.", true);
                    return;
                }

                const formData = new FormData();
                formData.append("archivo", file);

                const textoOriginal = descargarCertificadosCedulas instanceof HTMLButtonElement
                    ? descargarCertificadosCedulas.textContent
                    : "Descargar por plantilla";

                if (descargarCertificadosCedulas instanceof HTMLButtonElement) {
                    descargarCertificadosCedulas.disabled = true;
                    descargarCertificadosCedulas.textContent = "Preparando...";
                }

                try {
                    mostrarEstadoCertificadosMasivos("Leyendo plantilla y buscando cédulas...", false);
                    const data = await fetchJson(baseCertificadosCedulas, {
                        method: "POST",
                        headers: {
                            "RequestVerificationToken": tokenCertificadosMasivosInput.value,
                            "X-Requested-With": "XMLHttpRequest"
                        },
                        body: formData
                    });

                    await procesarRespuestaCertificados(data);
                } catch (error) {
                    mostrarEstadoCertificadosMasivos(
                        error instanceof Error ? error.message : "No fue posible preparar los certificados.",
                        true);
                } finally {
                    if (descargarCertificadosCedulas instanceof HTMLButtonElement) {
                        descargarCertificadosCedulas.disabled = false;
                        descargarCertificadosCedulas.textContent = textoOriginal ?? "Descargar por plantilla";
                    }
                }
            };

            const getEstadoCertificado = (evaluacionId) => {
                const separador = baseEstadoCertificado.includes("?") ? "&" : "?";
                return fetchJson(`${baseEstadoCertificado}${separador}id=${encodeURIComponent(evaluacionId)}`, {
                    headers: {
                        "X-Requested-With": "XMLHttpRequest"
                    }
                });
            };

            const abrirModalFirmaCertificado = (data, modo = "emitir") => {
                modoFirmaCertificado = modo;
                evaluacionFirmaCertificadoId = data?.evaluacionId || getSelectedEvaluacionId();

                if (textoFirmaCertificado) {
                    const etiqueta = data?.etiqueta ? ` de ${data.etiqueta}` : "";
                    textoFirmaCertificado.textContent = modoFirmaCertificado === "actualizar"
                        ? "Adjunta o actualiza tu firma. Se aceptan imágenes PNG o JPG."
                        : `Adjunta tu firma${etiqueta} para emitir el certificado.`;
                }

                if (guardarFirmaCertificado instanceof HTMLButtonElement) {
                    guardarFirmaCertificado.textContent = modoFirmaCertificado === "actualizar"
                        ? "Guardar firma"
                        : "Guardar firma y emitir";
                }

                if (firmaCertificadoArchivo instanceof HTMLInputElement) {
                    firmaCertificadoArchivo.value = "";
                }

                mostrarEstadoFirma("Selecciona una imagen PNG o JPG.", false);
                modalFirmaCertificado?.show();
            };

            const abrirModalActualizacionFirma = () => {
                const evaluacionId = getSelectedEvaluacionId();
                if (!evaluacionId) {
                    return;
                }

                abrirModalFirmaCertificado({ evaluacionId }, "actualizar");
            };

            const mostrarFirmaFaltanteOtro = (mensaje) => {
                if (firmaFaltanteOtroMensaje) {
                    firmaFaltanteOtroMensaje.textContent = mensaje || "Aún falta la firma del otro evaluador.";
                }

                if (modalFirmaFaltanteOtro) {
                    modalFirmaFaltanteOtro.show();
                } else {
                    window.alert(firmaFaltanteOtroMensaje?.textContent ?? "Aún falta la firma del otro evaluador.");
                }
            };

            const continuarSegunEstadoCertificado = (evaluacionId, data) => {
                if (data?.status === "ready") {
                    window.location.href = data.url || `${baseImprimir}?id=${encodeURIComponent(evaluacionId)}`;
                    return;
                }

                if (data?.status === "currentMissingSignature") {
                    abrirModalFirmaCertificado(data);
                    return;
                }

                if (data?.status === "otherMissingSignature") {
                    mostrarFirmaFaltanteOtro(data?.message);
                    return;
                }

                window.alert(data?.message || "No fue posible emitir el certificado.");
            };

            const emitirCertificadoSeleccionado = async () => {
                const evaluacionId = getSelectedEvaluacionId();
                if (!evaluacionId || !baseEstadoCertificado) {
                    return;
                }

                try {
                    const data = await getEstadoCertificado(evaluacionId);
                    continuarSegunEstadoCertificado(evaluacionId, data);
                } catch (error) {
                    const mensaje = error instanceof Error && error.message
                        ? error.message
                        : "No fue posible validar el certificado.";
                    window.alert(mensaje);
                }
            };

            const subirFirmaCertificado = async () => {
                if (!(firmaCertificadoArchivo instanceof HTMLInputElement) ||
                    !(guardarFirmaCertificado instanceof HTMLButtonElement) ||
                    !(tokenFirmaInput instanceof HTMLInputElement) ||
                    !baseSubirFirma ||
                    !evaluacionFirmaCertificadoId) {
                    return;
                }

                const file = firmaCertificadoArchivo.files?.[0];
                if (!(file instanceof File)) {
                    mostrarEstadoFirma("Selecciona una firma en PNG o JPG.", true);
                    return;
                }

                const formData = new FormData();
                formData.append("id", evaluacionFirmaCertificadoId);
                formData.append("archivo", file);

                const textoOriginal = guardarFirmaCertificado.textContent;
                guardarFirmaCertificado.disabled = true;
                guardarFirmaCertificado.textContent = "Guardando...";
                mostrarEstadoFirma("Validando y guardando la firma...", false);

                try {
                    await fetchJson(baseSubirFirma, {
                        method: "POST",
                        headers: {
                            "RequestVerificationToken": tokenFirmaInput.value,
                            "X-Requested-With": "XMLHttpRequest"
                        },
                        body: formData
                    });

                    mostrarEstadoFirma("Firma guardada correctamente.", false);
                    if (modoFirmaCertificado === "actualizar") {
                        window.setTimeout(() => {
                            modalFirmaCertificado?.hide();
                        }, 700);
                    } else {
                        const data = await getEstadoCertificado(evaluacionFirmaCertificadoId);
                        modalFirmaCertificado?.hide();
                        continuarSegunEstadoCertificado(evaluacionFirmaCertificadoId, data);
                    }
                } catch (error) {
                    const mensaje = error instanceof Error && error.message
                        ? error.message
                        : "No fue posible guardar la firma.";
                    mostrarEstadoFirma(mensaje, true);
                } finally {
                    guardarFirmaCertificado.disabled = false;
                    guardarFirmaCertificado.textContent = textoOriginal ?? (modoFirmaCertificado === "actualizar"
                        ? "Guardar firma"
                        : "Guardar firma y emitir");
                }
            };

            const exportarSeleccion = () => {
                if (exportandoEnCurso) {
                    return;
                }

                const idsSeleccionados = getIdsSeleccionados();
                if (!idsSeleccionados.length || !baseExportar || !(tokenExportarInput instanceof HTMLInputElement)) {
                    return;
                }

                const actualizarProgreso = (siguiente, mensaje) => {
                    progresoExportacion = Math.max(progresoExportacion, Math.min(siguiente, 100));
                    if (barraProgresoExportacion instanceof HTMLDivElement) {
                        barraProgresoExportacion.style.width = `${progresoExportacion}%`;
                        barraProgresoExportacion.textContent = `${progresoExportacion}%`;
                    }

                    if (textoEstadoExportacion) {
                        textoEstadoExportacion.textContent = mensaje;
                    }
                };

                const iniciarBloqueoExportacion = () => {
                    exportandoEnCurso = true;
                    setExportDisabled(true);
                    if (accionExportar instanceof HTMLButtonElement) {
                        accionExportar.textContent = "Exportando...";
                    }

                    progresoExportacion = 0;
                    actualizarProgreso(8, "Validando selección...");
                    modalExportar?.show();

                    if (intervaloProgresoExportacion) {
                        window.clearInterval(intervaloProgresoExportacion);
                    }

                    intervaloProgresoExportacion = window.setInterval(() => {
                        if (progresoExportacion < 92) {
                            actualizarProgreso(progresoExportacion + 6, "Generando archivo Excel...");
                        }
                    }, 500);
                };

                const finalizarBloqueoExportacion = () => {
                    if (intervaloProgresoExportacion) {
                        window.clearInterval(intervaloProgresoExportacion);
                        intervaloProgresoExportacion = null;
                    }

                    exportandoEnCurso = false;
                    if (accionExportar instanceof HTMLButtonElement) {
                        accionExportar.textContent = "Exportar resultados";
                    }

                    updateLinks();
                    window.setTimeout(() => {
                        modalExportar?.hide();
                    }, 450);
                };

                const descargarArchivo = (blob, fileName) => {
                    const enlace = document.createElement("a");
                    const fileUrl = window.URL.createObjectURL(blob);
                    enlace.href = fileUrl;
                    enlace.download = fileName;
                    document.body.appendChild(enlace);
                    enlace.click();
                    enlace.remove();
                    window.URL.revokeObjectURL(fileUrl);
                };

                const obtenerNombreArchivo = (contentDisposition) => {
                    if (!contentDisposition) {
                        return `Evaluaciones_${new Date().toISOString().slice(0, 19).replace(/[:T]/g, "_")}.xlsx`;
                    }

                    const match = contentDisposition.match(/filename\*?=(?:UTF-8''|\"?)([^\";]+)/i);
                    if (!match?.[1]) {
                        return "Evaluaciones.xlsx";
                    }

                    return decodeURIComponent(match[1]).replace(/\"/g, "");
                };

                iniciarBloqueoExportacion();
                fetch(baseExportar, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "RequestVerificationToken": tokenExportarInput.value
                    },
                    body: JSON.stringify({ ids: idsSeleccionados })
                })
                    .then(async (response) => {
                        if (!response.ok) {
                            throw new Error(await response.text());
                        }

                        actualizarProgreso(100, "Exportación completada.");
                        const blob = await response.blob();
                        const fileName = obtenerNombreArchivo(response.headers.get("Content-Disposition"));
                        descargarArchivo(blob, fileName);
                    })
                    .catch(() => {
                        window.alert("No fue posible exportar los resultados seleccionados.");
                    })
                    .finally(() => {
                        finalizarBloqueoExportacion();
                    });
            };

            const eliminarSeleccion = async () => {
                const idsSeleccionados = getIdsSeleccionados();
                if (!idsSeleccionados.length || !baseEliminar || !(tokenEliminarInput instanceof HTMLInputElement)) {
                    return;
                }

                const mensajeConfirmacion = idsSeleccionados.length === 1
                    ? "Se eliminará 1 evaluación y todos sus registros relacionados en Dataverse. Esta acción no se puede deshacer. ¿Deseas continuar?"
                    : `Se eliminarán ${idsSeleccionados.length} evaluaciones y todos sus registros relacionados en Dataverse. Esta acción no se puede deshacer. ¿Deseas continuar?`;

                if (!window.confirm(mensajeConfirmacion)) {
                    return;
                }

                const textoOriginal = accionEliminar instanceof HTMLButtonElement
                    ? accionEliminar.textContent
                    : "Eliminar seleccionadas";

                if (accionEliminar instanceof HTMLButtonElement) {
                    accionEliminar.disabled = true;
                    accionEliminar.textContent = "Eliminando...";
                }

                try {
                    const response = await fetch(baseEliminar, {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json",
                            "RequestVerificationToken": tokenEliminarInput.value
                        },
                        body: JSON.stringify({ ids: idsSeleccionados })
                    });

                    if (!response.ok) {
                        throw new Error(await response.text());
                    }

                    const data = await response.json();
                    if (data?.message) {
                        window.alert(data.message);
                    }

                    window.location.reload();
                } catch (error) {
                    const mensajeError = error instanceof Error && error.message
                        ? error.message
                        : "No fue posible eliminar las evaluaciones seleccionadas.";

                    window.alert(mensajeError);
                } finally {
                    if (accionEliminar instanceof HTMLButtonElement) {
                        accionEliminar.textContent = textoOriginal ?? "Eliminar seleccionadas";
                    }

                    updateLinks();
                }
            };

            const actualizarCeldaReporte = (evaluacionId, fileName, downloadUrl) => {
                const row = tabla.querySelector(`tbody tr[data-evaluacion-id="${evaluacionId}"]`);
                const cell = row?.querySelector(".reporte-firmado-cell");
                if (!row || !cell) {
                    return;
                }

                row.dataset.tieneReporteFirmado = "true";
                cell.innerHTML = "";

                const link = document.createElement("a");
                link.className = "reporte-firmado-link";
                link.href = downloadUrl;
                link.dataset.fileName = fileName;
                link.textContent = fileName;
                cell.appendChild(link);
            };

            const subirReporte = async (file) => {
                const filasSeleccionadas = getFilasSeleccionadas();
                if (filasSeleccionadas.length !== 1 || !baseSubirReporte) {
                    return;
                }

                const row = filasSeleccionadas[0];
                const evaluacionId = row.dataset.evaluacionId;
                const tokenInput = document.querySelector('#subirReporteFirmadoToken input[name="__RequestVerificationToken"]');
                if (!evaluacionId || !tokenInput || !(file instanceof File)) {
                    return;
                }

                const formData = new FormData();
                formData.append("id", evaluacionId);
                formData.append("archivo", file);

                accionSubirReporte.disabled = true;
                accionSubirReporte.textContent = "Subiendo...";

                try {
                    const response = await fetch(baseSubirReporte, {
                        method: "POST",
                        headers: {
                            "RequestVerificationToken": tokenInput.value
                        },
                        body: formData
                    });

                    if (!response.ok) {
                        throw new Error("No fue posible subir el reporte.");
                    }

                    const data = await response.json();
                    actualizarCeldaReporte(evaluacionId, data.fileName, data.downloadUrl);
                } catch (error) {
                    window.alert("No fue posible subir el reporte firmado.");
                } finally {
                    accionSubirReporte.textContent = "Subir reporte";
                    updateLinks();
                    if (archivoReporteFirmadoInput instanceof HTMLInputElement) {
                        archivoReporteFirmadoInput.value = "";
                    }
                }
            };

            const applyFilter = () => {
                const filtro = filtroTablaEvaluaciones instanceof HTMLInputElement
                    ? filtroTablaEvaluaciones.value.trim().toLowerCase()
                    : "";

                const rows = Array.from(tabla.querySelectorAll("tbody tr"));
                rows.forEach((row) => {
                    const proyecto = (row.dataset.proyecto ?? "").toLowerCase();
                    const cedula = (row.dataset.cedula ?? "").toLowerCase();
                    const coincide = !filtro || proyecto.includes(filtro) || cedula.includes(filtro);
                    row.style.display = coincide ? "" : "none";

                    if (!coincide) {
                        const checkbox = row.querySelector("input[name='evaluacionesSeleccionadas']");
                        if (checkbox instanceof HTMLInputElement) {
                            checkbox.checked = false;
                        }
                    }
                });

                updateLinks();
            };

            tabla.addEventListener("change", (event) => {
                const input = event.target;
                if (!(input instanceof HTMLInputElement) || input.type !== "checkbox") {
                    return;
                }

                updateLinks();
            });

            if (selectorTodasEvaluaciones instanceof HTMLInputElement) {
                selectorTodasEvaluaciones.addEventListener("change", () => {
                    getCheckboxesVisibles().forEach((input) => {
                        input.checked = selectorTodasEvaluaciones.checked;
                    });

                    updateLinks();
                });
            }

            accionImprimir?.addEventListener("click", (event) => {
                event.preventDefault();

                if (accionImprimir.getAttribute("aria-disabled") === "true") {
                    return;
                }

                emitirCertificadoSeleccionado();
            });

            [accionImprimir, accionCarpeta].forEach((accion) => {
                accion?.addEventListener("click", (event) => {
                    if (accion.getAttribute("aria-disabled") === "true") {
                        event.preventDefault();
                    }
                });
            });

            if (accionExportar instanceof HTMLButtonElement) {
                accionExportar.addEventListener("click", exportarSeleccion);
            }

            if (accionExportarCertificadosMasivos instanceof HTMLButtonElement) {
                accionExportarCertificadosMasivos.addEventListener("click", () => {
                    if (descargandoCertificadosEnCurso) {
                        return;
                    }

                    if (descargarPlantillaCertificados instanceof HTMLAnchorElement && basePlantillaCertificados) {
                        descargarPlantillaCertificados.href = basePlantillaCertificados;
                    }

                    if (certificadosArchivoCedulas instanceof HTMLInputElement) {
                        certificadosArchivoCedulas.value = "";
                    }

                    mostrarEstadoCertificadosMasivos("Selecciona un método de descarga.", false);
                    modalCertificadosMasivos?.show();
                });
            }

            if (descargarPlantillaCertificados instanceof HTMLAnchorElement && basePlantillaCertificados) {
                descargarPlantillaCertificados.href = basePlantillaCertificados;
            }

            if (descargarCertificadosFechas instanceof HTMLButtonElement) {
                descargarCertificadosFechas.addEventListener("click", prepararCertificadosPorFechas);
            }

            if (descargarCertificadosCedulas instanceof HTMLButtonElement) {
                descargarCertificadosCedulas.addEventListener("click", prepararCertificadosPorCedulas);
            }

            if (accionEliminar instanceof HTMLButtonElement) {
                accionEliminar.addEventListener("click", eliminarSeleccion);
            }

            if (accionFirmaEvaluador instanceof HTMLButtonElement) {
                accionFirmaEvaluador.addEventListener("click", () => {
                    if (accionFirmaEvaluador.disabled) {
                        return;
                    }

                    abrirModalActualizacionFirma();
                });
            }

            if (accionSubirReporte instanceof HTMLButtonElement && archivoReporteFirmadoInput instanceof HTMLInputElement) {
                accionSubirReporte.addEventListener("click", () => {
                    if (accionSubirReporte.disabled) {
                        return;
                    }

                    if (getFilasSeleccionadas().length !== 1) {
                        return;
                    }

                    archivoReporteFirmadoInput.click();
                });

                archivoReporteFirmadoInput.addEventListener("change", () => {
                    const file = archivoReporteFirmadoInput.files?.[0];
                    if (!file) {
                        return;
                    }

                    subirReporte(file);
                });
            }

            if (guardarFirmaCertificado instanceof HTMLButtonElement) {
                guardarFirmaCertificado.addEventListener("click", subirFirmaCertificado);
            }

            if (filtroTablaEvaluaciones instanceof HTMLInputElement) {
                filtroTablaEvaluaciones.addEventListener("input", applyFilter);
            }

            applyFilter();
        })();
    </script>
}
