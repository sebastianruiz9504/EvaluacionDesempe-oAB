@using EvaluacionDesempenoAB.ViewModels
@model IEnumerable<EvaluacionListaViewModel>

@{
    ViewData["Title"] = "Mis evaluaciones";
    var cedulaFiltro = ViewData["CedulaFiltro"] as string;
    var proyectoFiltro = ViewData["ProyectoFiltro"] as string;
    var hayEvaluaciones = Model.Any();
    var esSuperAdmin = ViewBag.EsSuperAdmin is bool valor && valor;
    var tiposFormularioCertificado = ViewBag.TiposFormularioCertificado as List<TipoFormularioOpcionViewModel> ?? new();
    var errorCarga = ViewBag.ErrorCargaEvaluaciones as string;
    var advertenciaCarga = ViewBag.AdvertenciaCargaEvaluaciones as string;
}

<h2 class="mt-4">Mis evaluaciones</h2>

@if (!string.IsNullOrWhiteSpace(errorCarga))
{
    <div class="alert alert-warning mt-3" role="alert">
        @errorCarga
    </div>
}

@if (!string.IsNullOrWhiteSpace(advertenciaCarga))
{
    <div class="alert alert-info mt-3" role="alert">
        @advertenciaCarga
    </div>
}

<form method="get" class="row g-2 align-items-end mt-1 mb-2">
    <div class="col-md-4">
        <label class="form-label mb-1" for="cedulaFiltro">Filtrar por cédula</label>
        <input id="cedulaFiltro"
               name="cedula"
               class="form-control"
               value="@cedulaFiltro"
               placeholder="Ej: 1012345678" />
    </div>
    <div class="col-md-4">
        <label class="form-label mb-1" for="proyectoFiltro">Filtrar por proyecto</label>
        <input id="proyectoFiltro"
               name="proyecto"
               class="form-control"
               value="@proyectoFiltro"
               placeholder="Ej: Acueducto Norte" />
    </div>
    <div class="col-md-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Aplicar filtros</button>
        @if (!string.IsNullOrWhiteSpace(cedulaFiltro) || !string.IsNullOrWhiteSpace(proyectoFiltro))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
        }
    </div>
</form>

@if (hayEvaluaciones || esSuperAdmin)
{
    <div class="card mt-3 shadow-sm border-0"
         data-evaluaciones-acciones
         data-base-imprimir="@Url.Action("ImprimirResultados", "Evaluaciones")"
         data-base-reevaluar="@Url.Action("Reevaluar", "Evaluaciones")"
         data-base-carpeta="@Url.Action("CarpetaUsuario", "Evaluaciones")"
         data-base-exportar="@Url.Action("ExportarExcel", "Evaluaciones")"
         data-base-subir-reporte="@Url.Action("SubirReporteFirmado", "Evaluaciones")">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                @if (hayEvaluaciones)
                {
                    <div class="col-12 col-xxl">
                        <div class="small text-muted text-uppercase fw-semibold mb-2">Selección</div>
                        <div class="d-flex flex-wrap align-items-center gap-3">
                            <div class="form-check mb-0">
                                <input id="seleccionarTodasEvaluaciones"
                                       type="checkbox"
                                       class="form-check-input"
                                       disabled />
                                <label class="form-check-label" for="seleccionarTodasEvaluaciones">
                                    Seleccionar todos
                                </label>
                            </div>
                            <span id="resumenSeleccion" class="text-muted small">
                                No hay evaluaciones seleccionadas.
                            </span>
                        </div>
                    </div>
                    <div class="col-12 col-xxl-auto">
                        <div class="small text-muted text-uppercase fw-semibold mb-2">Acciones individuales</div>
                        <div class="d-flex flex-wrap gap-2">
                            <a id="accionImprimir"
                               class="btn btn-sm btn-outline-success disabled"
                               href="#"
                               aria-disabled="true">
                                Imprimir resultados
                            </a>
                            <a id="accionCarpeta"
                               class="btn btn-sm btn-outline-secondary disabled"
                               href="#"
                               aria-disabled="true">
                                Carpeta usuario
                            </a>
                            <a id="accionReevaluar"
                               class="btn btn-sm btn-warning disabled"
                               href="#"
                               aria-disabled="true">
                                Reevaluar
                            </a>
                            <button id="accionSubirReporte"
                                    type="button"
                                    class="btn btn-sm btn-outline-primary"
                                    disabled>
                                Subir reporte
                            </button>
                        </div>
                    </div>
                    <div class="col-12 col-xxl-auto">
                        <div class="small text-muted text-uppercase fw-semibold mb-2">Acciones múltiples</div>
                        <div class="d-flex flex-wrap gap-2">
                            <button id="accionExportar"
                                    type="button"
                                    class="btn btn-sm btn-outline-dark"
                                    disabled>
                                Exportar resultados
                            </button>
                        </div>
                    </div>
                }
                @if (esSuperAdmin)
                {
                    <div class="col-12 col-xxl-auto">
                        <div class="small text-muted text-uppercase fw-semibold mb-2">Certificados</div>
                        <form method="get"
                              asp-action="CertificadoEnBlanco"
                              class="d-flex flex-wrap align-items-center gap-2">
                            <select name="tipoFormulario"
                                    class="form-select form-select-sm"
                                    style="min-width: 240px;"
                                    required>
                                <option value="">Selecciona tipo de formulario</option>
                                @foreach (var tipo in tiposFormularioCertificado)
                                {
                                    <option value="@tipo.Valor">@tipo.Nombre</option>
                                }
                            </select>
                            <button type="submit" class="btn btn-sm btn-outline-success">
                                Certificado en blanco
                            </button>
                        </form>
                    </div>
                }
            </div>

            @if (hayEvaluaciones)
            {
                <div id="ayudaAccionesEvaluaciones" class="small text-muted mt-3">
                    Selecciona una o varias evaluaciones para habilitar las acciones disponibles.
                </div>
            }
        </div>
    </div>
}

@if (!hayEvaluaciones)
{
    @if (string.IsNullOrWhiteSpace(errorCarga))
    {
        <div class="alert alert-info mt-3">
            No se han registrado evaluaciones aún.
        </div>
    }
}
else
{
    <div class="mt-3">
        <input id="filtroTablaEvaluaciones"
               type="text"
               class="form-control"
               placeholder="Filtrar por proyecto o cédula..." />
    </div>
    <div class="table-responsive mt-3">
        <table id="tablaMisEvaluaciones" class="table table-striped table-bordered align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width: 90px;">Seleccionar</th>
                    <th>ID evaluación</th>
                    <th>Fecha evaluación</th>
                    <th>Próxima evaluación</th>
                    <th>Nombre</th>
                    <th>Cédula</th>
                    <th>Gerencia</th>
                    <th>Proyecto</th>
                    <th>Nivel</th>
                    <th>Tipo</th>
                    <th>Resultado final</th>
                    <th>Evaluación normal</th>
                    <th>Evaluación SST</th>
                    <th>Reporte firmado</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var e in Model.OrderByDescending(x => x.FechaEvaluacion))
            {
                <tr data-evaluacion-id="@e.Id"
                    data-usuario-id="@e.UsuarioId"
                    data-puede-reevaluar="@e.PuedeReevaluar.ToString().ToLower()"
                    data-proyecto="@e.ProyectoUsuario"
                    data-cedula="@e.CedulaUsuario">
                    <td class="text-center">
                        <input type="checkbox"
                               name="evaluacionesSeleccionadas"
                               class="form-check-input"
                               aria-label="Seleccionar evaluación de @e.NombreUsuario" />
                    </td>
                    <td><code>@e.Id</code></td>
                    <td>@e.FechaEvaluacion.ToShortDateString()</td>
                    <td>
                        @if (e.ProximaEvaluacion.HasValue)
                        {
                            @e.ProximaEvaluacion.Value.ToShortDateString()
                        }
                    </td>
                    <td>@e.NombreUsuario</td>
                    <td>@e.CedulaUsuario</td>
                    <td>@e.GerenciaUsuario</td>
                    <td>@e.ProyectoUsuario</td>
                    <td>
                        @e.NivelNombre
                        @if (!string.IsNullOrWhiteSpace(e.NivelCodigo))
                        {
                            <span class="badge bg-secondary ms-1">@e.NivelCodigo</span>
                        }
                    </td>
                    <td>@e.TipoEvaluacion</td>
                    <td>
                        @if (e.ResultadoFinal.HasValue)
                        {
                            @e.ResultadoFinal.Value.ToString("0.##")<span>%</span>
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </td>
                    <td class="text-center">
                        @if (e.ResultadoEvaluacionNormal.HasValue)
                        {
                            <div class="fw-semibold">@e.ResultadoEvaluacionNormal.Value.ToString("0.##")%</div>
                        }
                        else
                        {
                            <div class="text-muted">-</div>
                        }

                        <span class="badge @(e.EvaluacionNormalCompleta ? "bg-success" : "bg-secondary") mt-1">
                            @(e.EvaluacionNormalCompleta ? "Completada" : "Pendiente")
                        </span>
                    </td>
                    <td class="text-center">
                        @if (e.ResultadoEvaluacionSst.HasValue)
                        {
                            <div class="fw-semibold">@e.ResultadoEvaluacionSst.Value.ToString("0.##")%</div>
                        }
                        else
                        {
                            <div class="text-muted">-</div>
                        }

                        <span class="badge @(e.EvaluacionSstCompleta ? "bg-success" : "bg-secondary") mt-1">
                            @(e.EvaluacionSstCompleta ? "Completada" : "Pendiente")
                        </span>
                    </td>
                    <td class="reporte-firmado-cell">
                        @if (e.TieneReporteFirmado)
                        {
                            <a class="reporte-firmado-link"
                               href="@Url.Action("DescargarReporteFirmado", "Evaluaciones", new { id = e.Id })"
                               data-file-name="@e.ReporteFirmadoNombre">
                                @e.ReporteFirmadoNombre
                            </a>
                        }
                        else
                        {
                            <span class="text-muted reporte-firmado-empty">Sin adjunto</span>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

<form id="subirReporteFirmadoToken" method="post" class="d-none">
    @Html.AntiForgeryToken()
</form>
<form id="exportarExcelToken" method="post" class="d-none">
    @Html.AntiForgeryToken()
</form>
<input id="archivoReporteFirmadoInput"
       type="file"
       class="d-none"
       accept=".pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg" />

<div class="modal fade" id="modalExportandoResultados" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Exportando resultados</h5>
            </div>
            <div class="modal-body">
                <p id="textoEstadoExportacion" class="mb-2 text-muted">Preparando exportación...</p>
                <div class="progress" role="progressbar" aria-label="Progreso de exportación" aria-valuemin="0" aria-valuemax="100">
                    <div id="barraProgresoExportacion"
                         class="progress-bar progress-bar-striped progress-bar-animated"
                         style="width: 0%;">
                        0%
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <script>
        (() => {
            const tabla = document.getElementById("tablaMisEvaluaciones");
            const acciones = document.querySelector("[data-evaluaciones-acciones]");
            const filtroTablaEvaluaciones = document.getElementById("filtroTablaEvaluaciones");
            const selectorTodasEvaluaciones = document.getElementById("seleccionarTodasEvaluaciones");
            const resumenSeleccion = document.getElementById("resumenSeleccion");
            const ayudaAccionesEvaluaciones = document.getElementById("ayudaAccionesEvaluaciones");
            const accionImprimir = document.getElementById("accionImprimir");
            const accionReevaluar = document.getElementById("accionReevaluar");
            const accionCarpeta = document.getElementById("accionCarpeta");
            const accionExportar = document.getElementById("accionExportar");
            const accionSubirReporte = document.getElementById("accionSubirReporte");
            const archivoReporteFirmadoInput = document.getElementById("archivoReporteFirmadoInput");
            const barraProgresoExportacion = document.getElementById("barraProgresoExportacion");
            const textoEstadoExportacion = document.getElementById("textoEstadoExportacion");
            const baseImprimir = acciones?.dataset.baseImprimir ?? "";
            const baseReevaluar = acciones?.dataset.baseReevaluar ?? "";
            const baseCarpeta = acciones?.dataset.baseCarpeta ?? "";
            const baseExportar = acciones?.dataset.baseExportar ?? "";
            const baseSubirReporte = acciones?.dataset.baseSubirReporte ?? "";
            const tokenExportarInput = document.querySelector('#exportarExcelToken input[name="__RequestVerificationToken"]');
            const modalExportarElement = document.getElementById("modalExportandoResultados");
            const modalExportar = modalExportarElement && window.bootstrap?.Modal
                ? new window.bootstrap.Modal(modalExportarElement, { backdrop: "static", keyboard: false })
                : null;
            let exportandoEnCurso = false;
            let progresoExportacion = 0;
            let intervaloProgresoExportacion = null;

            if (!tabla || !acciones) {
                return;
            }

            const setDisabled = (element, disabled) => {
                if (!element) {
                    return;
                }

                element.classList.toggle("disabled", disabled);
                element.setAttribute("aria-disabled", disabled ? "true" : "false");

                if (disabled) {
                    element.setAttribute("href", "#");
                }
            };

            const setExportDisabled = (disabled) => {
                if (accionExportar instanceof HTMLButtonElement) {
                    accionExportar.disabled = disabled;
                }
            };

            const setUploadDisabled = (disabled) => {
                if (accionSubirReporte instanceof HTMLButtonElement) {
                    accionSubirReporte.disabled = disabled;
                }
            };

            const getCheckboxesVisibles = () =>
                Array.from(tabla.querySelectorAll("tbody tr"))
                    .filter((row) => row instanceof HTMLTableRowElement && row.style.display !== "none")
                    .map((row) => row.querySelector("input[name='evaluacionesSeleccionadas']"))
                    .filter((input) => input instanceof HTMLInputElement);

            const getFilasSeleccionadas = () =>
                Array.from(tabla.querySelectorAll("tbody tr"))
                    .filter((row) => row instanceof HTMLTableRowElement && row.style.display !== "none")
                    .filter((row) => {
                        const input = row.querySelector("input[name='evaluacionesSeleccionadas']");
                        return input instanceof HTMLInputElement && input.checked;
                    });

            const getIdsSeleccionados = () =>
                getFilasSeleccionadas()
                    .map((row) => row.dataset.evaluacionId)
                    .filter((id) => !!id);

            const updateSelectionState = (selectedRows) => {
                const visibles = getCheckboxesVisibles();
                const seleccionadas = selectedRows.length;

                if (resumenSeleccion) {
                    if (!visibles.length) {
                        resumenSeleccion.textContent = "No hay evaluaciones visibles para seleccionar.";
                    } else if (!seleccionadas) {
                        resumenSeleccion.textContent = "No hay evaluaciones seleccionadas.";
                    } else if (seleccionadas === 1) {
                        resumenSeleccion.textContent = "1 evaluación seleccionada.";
                    } else {
                        resumenSeleccion.textContent = `${seleccionadas} evaluaciones seleccionadas.`;
                    }
                }

                if (selectorTodasEvaluaciones instanceof HTMLInputElement) {
                    const totalVisibles = visibles.length;
                    const totalSeleccionadas = visibles.filter((input) => input.checked).length;
                    selectorTodasEvaluaciones.disabled = totalVisibles === 0;
                    selectorTodasEvaluaciones.checked = totalVisibles > 0 && totalSeleccionadas === totalVisibles;
                    selectorTodasEvaluaciones.indeterminate = totalSeleccionadas > 0 && totalSeleccionadas < totalVisibles;
                }

                if (ayudaAccionesEvaluaciones) {
                    if (!seleccionadas) {
                        ayudaAccionesEvaluaciones.textContent = "Selecciona una o varias evaluaciones para habilitar las acciones disponibles.";
                    } else if (seleccionadas === 1) {
                        ayudaAccionesEvaluaciones.textContent = "Con una evaluación seleccionada puedes usar las acciones individuales y también exportar.";
                    } else {
                        ayudaAccionesEvaluaciones.textContent = "Con varias evaluaciones seleccionadas puedes exportar; las demás acciones requieren una sola evaluación.";
                    }
                }
            };

            const updateLinks = () => {
                const selectedRows = getFilasSeleccionadas();
                updateSelectionState(selectedRows);
                const row = selectedRows.length === 1 ? selectedRows[0] : null;

                if (!row) {
                    setDisabled(accionImprimir, true);
                    setDisabled(accionReevaluar, true);
                    setDisabled(accionCarpeta, true);
                    setExportDisabled(selectedRows.length === 0);
                    setUploadDisabled(true);
                    return;
                }

                const evaluacionId = row.dataset.evaluacionId;
                const usuarioId = row.dataset.usuarioId;
                const puedeReevaluar = row.dataset.puedeReevaluar === "true";

                accionImprimir.href = `${baseImprimir}?id=${evaluacionId}`;
                accionCarpeta.href = `${baseCarpeta}?usuarioId=${usuarioId}`;
                accionReevaluar.href = puedeReevaluar ? `${baseReevaluar}?id=${evaluacionId}` : "#";

                setDisabled(accionImprimir, false);
                setDisabled(accionCarpeta, false);
                setDisabled(accionReevaluar, !puedeReevaluar);
                setExportDisabled(false);
                setUploadDisabled(false);
            };

            const exportarSeleccion = () => {
                if (exportandoEnCurso) {
                    return;
                }

                const idsSeleccionados = getIdsSeleccionados();
                if (!idsSeleccionados.length || !baseExportar || !(tokenExportarInput instanceof HTMLInputElement)) {
                    return;
                }

                const actualizarProgreso = (siguiente, mensaje) => {
                    progresoExportacion = Math.max(progresoExportacion, Math.min(siguiente, 100));
                    if (barraProgresoExportacion instanceof HTMLDivElement) {
                        barraProgresoExportacion.style.width = `${progresoExportacion}%`;
                        barraProgresoExportacion.textContent = `${progresoExportacion}%`;
                    }

                    if (textoEstadoExportacion) {
                        textoEstadoExportacion.textContent = mensaje;
                    }
                };

                const iniciarBloqueoExportacion = () => {
                    exportandoEnCurso = true;
                    setExportDisabled(true);
                    if (accionExportar instanceof HTMLButtonElement) {
                        accionExportar.textContent = "Exportando...";
                    }

                    progresoExportacion = 0;
                    actualizarProgreso(8, "Validando selección...");
                    modalExportar?.show();

                    if (intervaloProgresoExportacion) {
                        window.clearInterval(intervaloProgresoExportacion);
                    }

                    intervaloProgresoExportacion = window.setInterval(() => {
                        if (progresoExportacion < 92) {
                            actualizarProgreso(progresoExportacion + 6, "Generando archivo Excel...");
                        }
                    }, 500);
                };

                const finalizarBloqueoExportacion = () => {
                    if (intervaloProgresoExportacion) {
                        window.clearInterval(intervaloProgresoExportacion);
                        intervaloProgresoExportacion = null;
                    }

                    exportandoEnCurso = false;
                    if (accionExportar instanceof HTMLButtonElement) {
                        accionExportar.textContent = "Exportar resultados";
                    }

                    updateLinks();
                    window.setTimeout(() => {
                        modalExportar?.hide();
                    }, 450);
                };

                const descargarArchivo = (blob, fileName) => {
                    const enlace = document.createElement("a");
                    const fileUrl = window.URL.createObjectURL(blob);
                    enlace.href = fileUrl;
                    enlace.download = fileName;
                    document.body.appendChild(enlace);
                    enlace.click();
                    enlace.remove();
                    window.URL.revokeObjectURL(fileUrl);
                };

                const obtenerNombreArchivo = (contentDisposition) => {
                    if (!contentDisposition) {
                        return `Evaluaciones_${new Date().toISOString().slice(0, 19).replace(/[:T]/g, "_")}.xlsx`;
                    }

                    const match = contentDisposition.match(/filename\*?=(?:UTF-8''|\"?)([^\";]+)/i);
                    if (!match?.[1]) {
                        return "Evaluaciones.xlsx";
                    }

                    return decodeURIComponent(match[1]).replace(/\"/g, "");
                };

                iniciarBloqueoExportacion();
                fetch(baseExportar, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "RequestVerificationToken": tokenExportarInput.value
                    },
                    body: JSON.stringify({ ids: idsSeleccionados })
                })
                    .then(async (response) => {
                        if (!response.ok) {
                            throw new Error(await response.text());
                        }

                        actualizarProgreso(100, "Exportación completada.");
                        const blob = await response.blob();
                        const fileName = obtenerNombreArchivo(response.headers.get("Content-Disposition"));
                        descargarArchivo(blob, fileName);
                    })
                    .catch(() => {
                        window.alert("No fue posible exportar los resultados seleccionados.");
                    })
                    .finally(() => {
                        finalizarBloqueoExportacion();
                    });
            };

            const actualizarCeldaReporte = (evaluacionId, fileName, downloadUrl) => {
                const row = tabla.querySelector(`tbody tr[data-evaluacion-id="${evaluacionId}"]`);
                const cell = row?.querySelector(".reporte-firmado-cell");
                if (!row || !cell) {
                    return;
                }

                row.dataset.tieneReporteFirmado = "true";
                cell.innerHTML = "";

                const link = document.createElement("a");
                link.className = "reporte-firmado-link";
                link.href = downloadUrl;
                link.dataset.fileName = fileName;
                link.textContent = fileName;
                cell.appendChild(link);
            };

            const subirReporte = async (file) => {
                const filasSeleccionadas = getFilasSeleccionadas();
                if (filasSeleccionadas.length !== 1 || !baseSubirReporte) {
                    return;
                }

                const row = filasSeleccionadas[0];
                const evaluacionId = row.dataset.evaluacionId;
                const tokenInput = document.querySelector('#subirReporteFirmadoToken input[name="__RequestVerificationToken"]');
                if (!evaluacionId || !tokenInput || !(file instanceof File)) {
                    return;
                }

                const formData = new FormData();
                formData.append("id", evaluacionId);
                formData.append("archivo", file);

                accionSubirReporte.disabled = true;
                accionSubirReporte.textContent = "Subiendo...";

                try {
                    const response = await fetch(baseSubirReporte, {
                        method: "POST",
                        headers: {
                            "RequestVerificationToken": tokenInput.value
                        },
                        body: formData
                    });

                    if (!response.ok) {
                        throw new Error("No fue posible subir el reporte.");
                    }

                    const data = await response.json();
                    actualizarCeldaReporte(evaluacionId, data.fileName, data.downloadUrl);
                } catch (error) {
                    window.alert("No fue posible subir el reporte firmado.");
                } finally {
                    accionSubirReporte.textContent = "Subir reporte";
                    updateLinks();
                    if (archivoReporteFirmadoInput instanceof HTMLInputElement) {
                        archivoReporteFirmadoInput.value = "";
                    }
                }
            };

            const applyFilter = () => {
                const filtro = filtroTablaEvaluaciones instanceof HTMLInputElement
                    ? filtroTablaEvaluaciones.value.trim().toLowerCase()
                    : "";

                const rows = Array.from(tabla.querySelectorAll("tbody tr"));
                rows.forEach((row) => {
                    const proyecto = (row.dataset.proyecto ?? "").toLowerCase();
                    const cedula = (row.dataset.cedula ?? "").toLowerCase();
                    const coincide = !filtro || proyecto.includes(filtro) || cedula.includes(filtro);
                    row.style.display = coincide ? "" : "none";

                    if (!coincide) {
                        const checkbox = row.querySelector("input[name='evaluacionesSeleccionadas']");
                        if (checkbox instanceof HTMLInputElement) {
                            checkbox.checked = false;
                        }
                    }
                });

                updateLinks();
            };

            tabla.addEventListener("change", (event) => {
                const input = event.target;
                if (!(input instanceof HTMLInputElement) || input.type !== "checkbox") {
                    return;
                }

                updateLinks();
            });

            if (selectorTodasEvaluaciones instanceof HTMLInputElement) {
                selectorTodasEvaluaciones.addEventListener("change", () => {
                    getCheckboxesVisibles().forEach((input) => {
                        input.checked = selectorTodasEvaluaciones.checked;
                    });

                    updateLinks();
                });
            }

            [accionImprimir, accionReevaluar, accionCarpeta].forEach((accion) => {
                accion?.addEventListener("click", (event) => {
                    if (accion.getAttribute("aria-disabled") === "true") {
                        event.preventDefault();
                    }
                });
            });

            if (accionExportar instanceof HTMLButtonElement) {
                accionExportar.addEventListener("click", exportarSeleccion);
            }

            if (accionSubirReporte instanceof HTMLButtonElement && archivoReporteFirmadoInput instanceof HTMLInputElement) {
                accionSubirReporte.addEventListener("click", () => {
                    if (accionSubirReporte.disabled) {
                        return;
                    }

                    if (getFilasSeleccionadas().length !== 1) {
                        return;
                    }

                    archivoReporteFirmadoInput.click();
                });

                archivoReporteFirmadoInput.addEventListener("change", () => {
                    const file = archivoReporteFirmadoInput.files?.[0];
                    if (!file) {
                        return;
                    }

                    subirReporte(file);
                });
            }

            if (filtroTablaEvaluaciones instanceof HTMLInputElement) {
                filtroTablaEvaluaciones.addEventListener("input", applyFilter);
            }

            applyFilter();
        })();
    </script>
}
