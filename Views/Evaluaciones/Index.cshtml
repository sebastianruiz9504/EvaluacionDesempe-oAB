@using EvaluacionDesempenoAB.ViewModels
@model IEnumerable<EvaluacionListaViewModel>

@{
    ViewData["Title"] = "Mis evaluaciones";
    var cedulaFiltro = ViewData["CedulaFiltro"] as string;
    var proyectoFiltro = ViewData["ProyectoFiltro"] as string;
    var hayEvaluaciones = Model.Any();
    var esSuperAdmin = ViewBag.EsSuperAdmin is bool valor && valor;
    var tiposFormularioCertificado = ViewBag.TiposFormularioCertificado as List<TipoFormularioOpcionViewModel> ?? new();
    var errorCarga = ViewBag.ErrorCargaEvaluaciones as string;
    var advertenciaCarga = ViewBag.AdvertenciaCargaEvaluaciones as string;
}

<h2 class="mt-4">Mis evaluaciones</h2>

@if (!string.IsNullOrWhiteSpace(errorCarga))
{
    <div class="alert alert-warning mt-3" role="alert">
        @errorCarga
    </div>
}

@if (!string.IsNullOrWhiteSpace(advertenciaCarga))
{
    <div class="alert alert-info mt-3" role="alert">
        @advertenciaCarga
    </div>
}

<form method="get" class="row g-2 align-items-end mt-1 mb-2">
    <div class="col-md-4">
        <label class="form-label mb-1" for="cedulaFiltro">Filtrar por cédula</label>
        <input id="cedulaFiltro"
               name="cedula"
               class="form-control"
               value="@cedulaFiltro"
               placeholder="Ej: 1012345678" />
    </div>
    <div class="col-md-4">
        <label class="form-label mb-1" for="proyectoFiltro">Filtrar por proyecto</label>
        <input id="proyectoFiltro"
               name="proyecto"
               class="form-control"
               value="@proyectoFiltro"
               placeholder="Ej: Acueducto Norte" />
    </div>
    <div class="col-md-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Aplicar filtros</button>
        @if (!string.IsNullOrWhiteSpace(cedulaFiltro) || !string.IsNullOrWhiteSpace(proyectoFiltro))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
        }
    </div>
</form>

<div class="d-flex flex-wrap gap-2 align-items-center mt-3"
     data-evaluaciones-acciones
     data-base-imprimir="@Url.Action("ImprimirResultados", "Evaluaciones")"
     data-base-reevaluar="@Url.Action("Reevaluar", "Evaluaciones")"
     data-base-carpeta="@Url.Action("CarpetaUsuario", "Evaluaciones")"
     data-base-exportar="@Url.Action("ExportarExcel", "Evaluaciones")"
     data-base-subir-reporte="@Url.Action("SubirReporteFirmado", "Evaluaciones")">
    @if (hayEvaluaciones)
    {
        <span class="text-muted">Selecciona una evaluación para habilitar las acciones dependientes de una evaluación.</span>
        <a id="accionImprimir"
           class="btn btn-sm btn-outline-success disabled"
           href="#"
           aria-disabled="true">
            Imprimir resultados
        </a>
    }
    @if (esSuperAdmin)
    {
        <form method="get"
              asp-action="CertificadoEnBlanco"
              class="d-flex flex-wrap align-items-center gap-2">
            <select name="tipoFormulario"
                    class="form-select form-select-sm"
                    style="min-width: 240px;"
                    required>
                <option value="">Selecciona tipo de formulario</option>
                @foreach (var tipo in tiposFormularioCertificado)
                {
                    <option value="@tipo.Valor">@tipo.Nombre</option>
                }
            </select>
            <button type="submit" class="btn btn-sm btn-outline-success">
                Certificado en blanco
            </button>
        </form>
    }
    @if (hayEvaluaciones)
    {
        <a id="accionReevaluar"
           class="btn btn-sm btn-warning disabled"
           href="#"
           aria-disabled="true">
            Reevaluar
        </a>
        <a id="accionCarpeta"
           class="btn btn-sm btn-outline-secondary disabled"
           href="#"
           aria-disabled="true">
            Carpeta usuario
        </a>
        <button id="accionExportar"
                type="button"
                class="btn btn-sm btn-outline-dark"
                disabled>
            Exportar resultados
        </button>
        <button id="accionSubirReporte"
                type="button"
                class="btn btn-sm btn-outline-primary"
                disabled>
            Subir reporte
        </button>
    }
</div>

@if (!hayEvaluaciones)
{
    @if (string.IsNullOrWhiteSpace(errorCarga))
    {
        <div class="alert alert-info mt-3">
            No se han registrado evaluaciones aún.
        </div>
    }
}
else
{
    <div class="mt-3">
        <input id="filtroTablaEvaluaciones"
               type="text"
               class="form-control"
               placeholder="Filtrar por proyecto o cédula..." />
    </div>
    <table class="table table-striped table-bordered mt-3">
        <thead class="table-light">
            <tr>
                <th style="width: 90px;">Seleccionar</th>
                <th>Fecha evaluación</th>
                <th>Próxima evaluación</th>
                <th>Nombre</th>
                <th>Cédula</th>
                <th>Gerencia</th>
                <th>Proyecto</th>
                <th>Nivel</th>
                <th>Tipo</th>
                <th>Resultado final</th>
                <th>Evaluación normal</th>
                <th>Evaluación SST</th>
                <th>Reporte firmado</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var e in Model.OrderByDescending(x => x.FechaEvaluacion))
        {
            <tr data-evaluacion-id="@e.Id"
                data-usuario-id="@e.UsuarioId"
                data-puede-reevaluar="@e.PuedeReevaluar.ToString().ToLower()"
                data-proyecto="@e.ProyectoUsuario"
                data-cedula="@e.CedulaUsuario">
                <td class="text-center">
                    <input type="checkbox"
                           name="evaluacionesSeleccionadas"
                           class="form-check-input"
                           aria-label="Seleccionar evaluación de @e.NombreUsuario" />
                </td>
                <td>@e.FechaEvaluacion.ToShortDateString()</td>
                <td>
                    @if (e.ProximaEvaluacion.HasValue)
                    {
                        @e.ProximaEvaluacion.Value.ToShortDateString()
                    }
                </td>
                <td>@e.NombreUsuario</td>
                <td>@e.CedulaUsuario</td>
                <td>@e.GerenciaUsuario</td>
                <td>@e.ProyectoUsuario</td>
                <td>
                    @e.NivelNombre
                    @if (!string.IsNullOrWhiteSpace(e.NivelCodigo))
                    {
                        <span class="badge bg-secondary ms-1">@e.NivelCodigo</span>
                    }
                </td>
                <td>@e.TipoEvaluacion</td>
                <td>
                    @if (e.ResultadoFinal.HasValue)
                    {
                        @e.ResultadoFinal.Value.ToString("0.##")<span>%</span>
                    }
                    else
                    {
                        <span>-</span>
                    }
                </td>
                <td class="text-center">
                    @if (e.EvaluacionNormalCompleta)
                    {
                        <span class="badge bg-success">Completada</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Pendiente</span>
                    }
                </td>
                <td class="text-center">
                    @if (e.EvaluacionSstCompleta)
                    {
                        <span class="badge bg-success">Completada</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Pendiente</span>
                    }
                </td>
                <td class="reporte-firmado-cell">
                    @if (e.TieneReporteFirmado)
                    {
                        <a class="reporte-firmado-link"
                           href="@Url.Action("DescargarReporteFirmado", "Evaluaciones", new { id = e.Id })"
                           data-file-name="@e.ReporteFirmadoNombre">
                            @e.ReporteFirmadoNombre
                        </a>
                    }
                    else
                    {
                        <span class="text-muted reporte-firmado-empty">Sin adjunto</span>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
}

<form id="subirReporteFirmadoToken" method="post" class="d-none">
    @Html.AntiForgeryToken()
</form>
<input id="archivoReporteFirmadoInput"
       type="file"
       class="d-none"
       accept=".pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg" />

@section Scripts
{
    <script>
        (() => {
            const tabla = document.querySelector("table");
            const acciones = document.querySelector("[data-evaluaciones-acciones]");
            const filtroTablaEvaluaciones = document.getElementById("filtroTablaEvaluaciones");
            const accionImprimir = document.getElementById("accionImprimir");
            const accionReevaluar = document.getElementById("accionReevaluar");
            const accionCarpeta = document.getElementById("accionCarpeta");
            const accionExportar = document.getElementById("accionExportar");
            const accionSubirReporte = document.getElementById("accionSubirReporte");
            const archivoReporteFirmadoInput = document.getElementById("archivoReporteFirmadoInput");
            const baseImprimir = acciones?.dataset.baseImprimir ?? "";
            const baseReevaluar = acciones?.dataset.baseReevaluar ?? "";
            const baseCarpeta = acciones?.dataset.baseCarpeta ?? "";
            const baseExportar = acciones?.dataset.baseExportar ?? "";
            const baseSubirReporte = acciones?.dataset.baseSubirReporte ?? "";

            if (!tabla || !acciones) {
                return;
            }

            const setDisabled = (element, disabled) => {
                if (!element) {
                    return;
                }

                element.classList.toggle("disabled", disabled);
                element.setAttribute("aria-disabled", disabled ? "true" : "false");

                if (disabled) {
                    element.setAttribute("href", "#");
                }
            };

            const setExportDisabled = (disabled) => {
                if (accionExportar instanceof HTMLButtonElement) {
                    accionExportar.disabled = disabled;
                }
            };

            const setUploadDisabled = (disabled) => {
                if (accionSubirReporte instanceof HTMLButtonElement) {
                    accionSubirReporte.disabled = disabled;
                }
            };

            const getFilasSeleccionadas = () =>
                Array.from(tabla.querySelectorAll("tbody input[type='checkbox']:checked"))
                    .map((input) => input.closest("tr"))
                    .filter((row) => row instanceof HTMLTableRowElement);

            const getIdsSeleccionados = () =>
                getFilasSeleccionadas()
                    .map((row) => row.dataset.evaluacionId)
                    .filter((id) => !!id);

            const updateLinks = () => {
                const selectedRows = getFilasSeleccionadas();
                const row = selectedRows[0];

                if (!row) {
                    setDisabled(accionImprimir, true);
                    setDisabled(accionReevaluar, true);
                    setDisabled(accionCarpeta, true);
                    setExportDisabled(true);
                    setUploadDisabled(true);
                    return;
                }

                const evaluacionId = row.dataset.evaluacionId;
                const usuarioId = row.dataset.usuarioId;
                const puedeReevaluar = row.dataset.puedeReevaluar === "true";
                const singleSelection = selectedRows.length === 1;

                accionImprimir.href = `${baseImprimir}?id=${evaluacionId}`;
                accionCarpeta.href = `${baseCarpeta}?usuarioId=${usuarioId}`;
                accionReevaluar.href = puedeReevaluar ? `${baseReevaluar}?id=${evaluacionId}` : "#";

                setDisabled(accionImprimir, false);
                setDisabled(accionCarpeta, false);
                setDisabled(accionReevaluar, !puedeReevaluar);
                setExportDisabled(false);
                setUploadDisabled(!singleSelection);
            };

            const exportarSeleccion = () => {
                const idsSeleccionados = getIdsSeleccionados();
                if (!idsSeleccionados.length || !baseExportar) {
                    return;
                }

                const query = idsSeleccionados
                    .map((id) => `ids=${encodeURIComponent(id)}`)
                    .join("&");

                window.location.href = `${baseExportar}?${query}`;
            };

            const actualizarCeldaReporte = (evaluacionId, fileName, downloadUrl) => {
                const row = tabla.querySelector(`tbody tr[data-evaluacion-id="${evaluacionId}"]`);
                const cell = row?.querySelector(".reporte-firmado-cell");
                if (!row || !cell) {
                    return;
                }

                row.dataset.tieneReporteFirmado = "true";
                cell.innerHTML = "";

                const link = document.createElement("a");
                link.className = "reporte-firmado-link";
                link.href = downloadUrl;
                link.dataset.fileName = fileName;
                link.textContent = fileName;
                cell.appendChild(link);
            };

            const subirReporte = async (file) => {
                const filasSeleccionadas = getFilasSeleccionadas();
                if (filasSeleccionadas.length !== 1 || !baseSubirReporte) {
                    return;
                }

                const row = filasSeleccionadas[0];
                const evaluacionId = row.dataset.evaluacionId;
                const tokenInput = document.querySelector('#subirReporteFirmadoToken input[name="__RequestVerificationToken"]');
                if (!evaluacionId || !tokenInput || !(file instanceof File)) {
                    return;
                }

                const formData = new FormData();
                formData.append("id", evaluacionId);
                formData.append("archivo", file);

                accionSubirReporte.disabled = true;
                accionSubirReporte.textContent = "Subiendo...";

                try {
                    const response = await fetch(baseSubirReporte, {
                        method: "POST",
                        headers: {
                            "RequestVerificationToken": tokenInput.value
                        },
                        body: formData
                    });

                    if (!response.ok) {
                        throw new Error("No fue posible subir el reporte.");
                    }

                    const data = await response.json();
                    actualizarCeldaReporte(evaluacionId, data.fileName, data.downloadUrl);
                } catch (error) {
                    window.alert("No fue posible subir el reporte firmado.");
                } finally {
                    accionSubirReporte.textContent = "Subir reporte";
                    updateLinks();
                    if (archivoReporteFirmadoInput instanceof HTMLInputElement) {
                        archivoReporteFirmadoInput.value = "";
                    }
                }
            };

            const applyFilter = () => {
                const filtro = filtroTablaEvaluaciones instanceof HTMLInputElement
                    ? filtroTablaEvaluaciones.value.trim().toLowerCase()
                    : "";

                const rows = Array.from(tabla.querySelectorAll("tbody tr"));
                rows.forEach((row) => {
                    const proyecto = (row.dataset.proyecto ?? "").toLowerCase();
                    const cedula = (row.dataset.cedula ?? "").toLowerCase();
                    const coincide = !filtro || proyecto.includes(filtro) || cedula.includes(filtro);
                    row.style.display = coincide ? "" : "none";
                });
            };

            tabla.addEventListener("change", (event) => {
                const input = event.target;
                if (!(input instanceof HTMLInputElement) || input.type !== "checkbox") {
                    return;
                }

                updateLinks();
            });

            [accionImprimir, accionReevaluar, accionCarpeta].forEach((accion) => {
                accion?.addEventListener("click", (event) => {
                    if (accion.getAttribute("aria-disabled") === "true") {
                        event.preventDefault();
                    }
                });
            });

            if (accionExportar instanceof HTMLButtonElement) {
                accionExportar.addEventListener("click", exportarSeleccion);
            }

            if (accionSubirReporte instanceof HTMLButtonElement && archivoReporteFirmadoInput instanceof HTMLInputElement) {
                accionSubirReporte.addEventListener("click", () => {
                    if (accionSubirReporte.disabled) {
                        return;
                    }

                    if (getFilasSeleccionadas().length !== 1) {
                        return;
                    }

                    archivoReporteFirmadoInput.click();
                });

                archivoReporteFirmadoInput.addEventListener("change", () => {
                    const file = archivoReporteFirmadoInput.files?.[0];
                    if (!file) {
                        return;
                    }

                    subirReporte(file);
                });
            }

            if (filtroTablaEvaluaciones instanceof HTMLInputElement) {
                filtroTablaEvaluaciones.addEventListener("input", applyFilter);
            }

            updateLinks();
            applyFilter();
        })();
    </script>
}
