@using EvaluacionDesempenoAB.ViewModels
@model CarpetaUsuarioViewModel

@{
    ViewData["Title"] = "Carpeta del usuario";
    var fotoUrl = Url.Action("Foto", "Usuarios", new { id = Model.UsuarioId }) ?? string.Empty;
}

<h2 class="mt-4">Carpeta de @Model.NombreUsuario (@Model.CedulaUsuario)</h2>

<div class="card mt-3 shadow-sm border-0">
    <div class="card-body">
        <div class="row g-3 align-items-center">
            <div class="col-12 col-lg">
                <div class="row g-2">
                    <div class="col-md-6">
                        <div class="small text-muted">Cargo</div>
                        <div class="fw-semibold">@(string.IsNullOrWhiteSpace(Model.Cargo) ? "-" : Model.Cargo)</div>
                    </div>
                    <div class="col-md-6">
                        <div class="small text-muted">Gerencia</div>
                        <div class="fw-semibold">@(string.IsNullOrWhiteSpace(Model.Gerencia) ? "-" : Model.Gerencia)</div>
                    </div>
                    <div class="col-md-6">
                        <div class="small text-muted">Proyecto</div>
                        <div class="fw-semibold">@(string.IsNullOrWhiteSpace(Model.Proyecto) ? "-" : Model.Proyecto)</div>
                    </div>
                    <div class="col-md-6">
                        <div class="small text-muted">Correo electrónico</div>
                        <div class="fw-semibold text-break">@(string.IsNullOrWhiteSpace(Model.CorreoElectronico) ? "-" : Model.CorreoElectronico)</div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-lg-auto">
                <div class="ab-user-photo-panel">
                    <img src="@fotoUrl"
                         alt="Foto de @Model.NombreUsuario"
                         class="ab-user-photo-panel-image" />
                </div>
            </div>
        </div>
    </div>
</div>

<h4 class="mt-4">Historial de evaluaciones</h4>

@if (!Model.Evaluaciones.Any())
{
    <div class="alert alert-info mt-2">
        No se han registrado evaluaciones para este usuario.
    </div>
}
else
{
    <table class="table table-striped table-bordered mt-3">
        <thead class="table-light">
            <tr>
                <th>Fecha evaluación</th>
                <th>Próxima evaluación</th>
                <th>Nivel</th>
                <th>Tipo</th>
                <th>Evaluación normal</th>
                <th>Evaluación SST</th>
                <th style="width: 220px;">Acciones</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var e in Model.Evaluaciones.OrderByDescending(x => x.FechaEvaluacion))
        {
            <tr>
                <td>@e.FechaEvaluacion.ToShortDateString()</td>
                <td>
                    @if (e.ProximaEvaluacion.HasValue)
                    {
                        @e.ProximaEvaluacion.Value.ToShortDateString()
                    }
                </td>
                <td>
                    @e.NivelNombre
                    @if (!string.IsNullOrWhiteSpace(e.NivelCodigo))
                    {
                        <span class="badge bg-secondary ms-1">@e.NivelCodigo</span>
                    }
                </td>
                <td>@e.TipoEvaluacion</td>
                <td class="text-center">
                    @if (e.EvaluacionNormalCompleta)
                    {
                        <span class="badge bg-success">Completada</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Pendiente</span>
                    }
                </td>
                <td class="text-center">
                    @if (e.EvaluacionSstCompleta)
                    {
                        <span class="badge bg-success">Completada</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Pendiente</span>
                    }
                </td>
                <td>
                    <a asp-controller="Evaluaciones"
                       asp-action="Reporte"
                       asp-route-id="@e.Id"
                       class="btn btn-sm btn-outline-primary me-2">
                        Ver reporte
                    </a>

                    @if (e.PuedeReevaluar)
                    {
                        <a asp-controller="Evaluaciones"
                           asp-action="Reevaluar"
                           asp-route-id="@e.Id"
                           class="btn btn-sm btn-warning">
                            Reevaluar
                        </a>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
}

<div class="mt-3">
    <a asp-controller="Usuarios" asp-action="Index" class="btn btn-secondary">
        Volver a usuarios
    </a>
</div>
