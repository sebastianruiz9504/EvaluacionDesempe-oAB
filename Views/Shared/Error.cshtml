@model ErrorViewModel
@{
    ViewData["Title"] = "Error en la solicitud";
}

<div class="container mt-5">
    <div class="alert alert-danger shadow-sm" role="alert">
        <h1 class="h3 mb-2">No pudimos procesar la solicitud</h1>
        <p class="mb-0">
            Contacta a soporte y comparte el detalle técnico de esta pantalla para poder revisar el caso.
        </p>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <h2 class="h5 mb-3">Detalle para soporte</h2>

            <dl class="row mb-0">
                <dt class="col-sm-3">Fecha</dt>
                <dd class="col-sm-9">@Model.Timestamp.ToString("yyyy-MM-dd HH:mm:ss zzz")</dd>

                <dt class="col-sm-3">Código</dt>
                <dd class="col-sm-9"><code>@Model.StatusCode</code></dd>

                @if (!string.IsNullOrWhiteSpace(Model.Method))
                {
                    <dt class="col-sm-3">Método</dt>
                    <dd class="col-sm-9"><code>@Model.Method</code></dd>
                }

                @if (!string.IsNullOrWhiteSpace(Model.Path))
                {
                    <dt class="col-sm-3">Ruta</dt>
                    <dd class="col-sm-9"><code>@Model.Path</code></dd>
                }

                @if (Model.ShowRequestId)
                {
                    <dt class="col-sm-3">Request ID</dt>
                    <dd class="col-sm-9"><code>@Model.RequestId</code></dd>
                }

                @if (!string.IsNullOrWhiteSpace(Model.ExceptionType))
                {
                    <dt class="col-sm-3">Tipo de error</dt>
                    <dd class="col-sm-9"><code>@Model.ExceptionType</code></dd>
                }

                @if (!string.IsNullOrWhiteSpace(Model.ExceptionMessage))
                {
                    <dt class="col-sm-3">Mensaje</dt>
                    <dd class="col-sm-9">@Model.ExceptionMessage</dd>
                }
            </dl>

            @if (!string.IsNullOrWhiteSpace(Model.TechnicalDetail))
            {
                <hr />
                <pre class="bg-light border rounded p-3 mb-0 small text-break">@Model.TechnicalDetail</pre>
            }
        </div>
    </div>

    <div class="mt-3">
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Volver al inicio</a>
    </div>
</div>
